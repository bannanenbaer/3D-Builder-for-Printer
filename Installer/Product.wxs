<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!-- In WiX v6/v7 im Jahr 2026 ist der ProductCode jetzt Pflicht -->
  <Package Name="3D Builder Pro" 
           Manufacturer="Bannanenbaer" 
           Version="1.0.0.0" 
           UpgradeCode="12345678-1234-1234-1234-123456789ABC"
           Language="1031">

    <MajorUpgrade DowngradeErrorMessage="Eine neuere Version von [ProductName] ist bereits installiert." />

    <!-- Standard-Icon für Programme & Funktionen -->
    <Icon Id="icon.ico" SourceFile="..\CSharpUI\Resources\icon.ico"/>
    <Property Id="ARPPRODUCTICON" Value="icon.ico" />

    <Feature Id="MainFeature" Title="3D Builder Pro" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>

    <!-- UI vorerst deaktiviert, um WIX0144 Fehler zu vermeiden -->
    <!-- <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" /> -->
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="3D Builder Pro" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="*">
        <!-- Pfad für .NET 10 Release-Build -->
        <File Id="ThreeDBuilderEXE" 
              Source="..\CSharpUI\bin\Release\net10.0-windows\ThreeDBuilder.exe" 
              KeyPath="yes" />
        
        <!-- Desktop-Verknüpfung -->
        <Shortcut Id="DesktopShortcut"
                  Directory="DesktopFolder"
                  Name="3D Builder Pro"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="icon.ico"
                  Advertise="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
