<UserControl x:Class="ThreeDBuilder.Views.AssistantPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ThreeDBuilder.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="360" Height="520"
             Background="Transparent">

    <Grid>
        <Border Background="#131920"
                BorderBrush="#3B82F6"
                BorderThickness="2"
                CornerRadius="16"
                Effect="{StaticResource DropShadowEffect}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header -->
                    <RowDefinition Height="*"/>      <!-- Chat -->
                    <RowDefinition Height="Auto"/>   <!-- Typing indicator -->
                    <RowDefinition Height="Auto"/>   <!-- Input -->
                </Grid.RowDefinitions>

                <!-- ── Header: Mascot + Name + Close ──────────────────────── -->
                <Border Grid.Row="0"
                        Background="#0A0F16"
                        CornerRadius="14,14,0,0"
                        Padding="12,10,12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Mascot (auto-starts idle float + blink on Loaded) -->
                        <local:MascotAnimationView Grid.Column="0"
                                                   Width="72" Height="88"
                                                   VerticalAlignment="Bottom"
                                                   Margin="0,0,4,0"/>

                        <!-- Name + status -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0">
                            <TextBlock Text="Brixl"
                                       FontSize="17" FontWeight="Bold"
                                       Foreground="#F8FAFC"/>
                            <TextBlock Text="Dein 3D-Assistent 🤖"
                                       FontSize="10" Foreground="#60A5FA"/>
                            <TextBlock Text="Tippe eine Frage oder beschreibe eine Form!"
                                       FontSize="9" Foreground="#64748B"
                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Close -->
                        <Button Grid.Column="2"
                                Command="{Binding DataContext.ToggleAssistantCommand,
                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#64748B"
                                VerticalAlignment="Top"
                                Padding="4" Width="30" Height="30">
                            <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- ── Chat messages ───────────────────────────────────────── -->
                <ScrollViewer x:Name="ChatScroll"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="10,6">
                    <ItemsControl x:Name="MessageList" ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">

                                    <!-- Bot bubble (left-aligned) -->
                                    <Grid HorizontalAlignment="Left" MaxWidth="272"
                                          Visibility="{Binding IsBot,
                                              Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Mini bot avatar -->
                                        <Ellipse Grid.Column="0" Width="24" Height="24"
                                                 VerticalAlignment="Bottom" Margin="0,0,4,4">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="#40D9D9" Offset="0"/>
                                                    <GradientStop Color="#20B2AA" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <!-- Mini face on avatar -->
                                        <Ellipse Grid.Column="0" Width="5" Height="4" Fill="White"
                                                 HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                 Margin="5,0,0,11"/>
                                        <Ellipse Grid.Column="0" Width="5" Height="4" Fill="White"
                                                 HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                 Margin="14,0,0,11"/>

                                        <!-- Bubble -->
                                        <Border Grid.Column="1"
                                                Background="#1E3A4A"
                                                CornerRadius="14,14,14,4"
                                                Padding="12,9">
                                            <TextBlock Text="{Binding Text}"
                                                       Foreground="#E2E8F0"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       LineHeight="20"/>
                                        </Border>
                                    </Grid>

                                    <!-- User bubble (right-aligned) -->
                                    <Border HorizontalAlignment="Right" MaxWidth="250"
                                            Background="#1D4ED8"
                                            CornerRadius="14,14,4,14"
                                            Padding="12,9"
                                            Visibility="{Binding IsUser,
                                                Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="{Binding Text}"
                                                   Foreground="White"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   LineHeight="20"/>
                                    </Border>

                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- ── Typing indicator ─────────────────────────────────────── -->
                <Border Grid.Row="2" Padding="14,5"
                        Visibility="{Binding IsTyping,
                            Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="#60A5FA" Margin="0,0,4,0"/>
                        <Ellipse Width="7" Height="7" Fill="#60A5FA" Margin="0,0,4,0" Opacity="0.7"/>
                        <Ellipse Width="7" Height="7" Fill="#60A5FA" Opacity="0.4"/>
                        <TextBlock Text=" Brixl denkt nach…"
                                   Foreground="#60A5FA" FontSize="11" FontStyle="Italic"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- ── Input area ───────────────────────────────────────────── -->
                <Border Grid.Row="3"
                        Background="#0A0F16"
                        CornerRadius="0,0,14,14"
                        Padding="10,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="InputBox"
                                 Grid.Column="0"
                                 Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Frage stellen oder Form beschreiben…"
                                 Style="{StaticResource MaterialDesignTextBox}"
                                 Foreground="#F8FAFC"
                                 Background="#1A2535"
                                 BorderBrush="#334155"
                                 Padding="12,8"
                                 FontSize="12"
                                 MaxHeight="80"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="False"
                                 KeyDown="OnInputKeyDown"/>

                        <Button Grid.Column="1"
                                Command="{Binding SendCommand}"
                                Width="40" Height="40"
                                Margin="8,0,0,0"
                                Background="#3B82F6"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="Senden (Enter)">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                            <materialDesign:PackIcon Kind="Send" Width="18" Height="18" Foreground="White"/>
                        </Button>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>
</UserControl>
