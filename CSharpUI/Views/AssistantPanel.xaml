<UserControl x:Class="ThreeDBuilder.Views.AssistantPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ThreeDBuilder.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="300"
             Background="Transparent">

    <!--
        Layout (top → bottom):
          1. Speech bubble  – shows the latest Brixl message (× to close)
          2. Brixl mascot   – clickable to toggle the speech bubble
          3. Input bar      – [○ clock/history]  [text input]  [➡ send]
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Speech bubble  -->
            <RowDefinition Height="Auto"/>   <!-- Mascot         -->
            <RowDefinition Height="Auto"/>   <!-- Input bar      -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 0 – Speech bubble (latest bot message + × close)
        ════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0"
              Visibility="{Binding IsChatOpen,
                  Converter={StaticResource BoolToVisibilityConverter}}"
              Margin="0,0,0,0">

            <!-- Outer glow / shadow card -->
            <Border Background="#F0131920"
                    BorderBrush="#3B82F6"
                    BorderThickness="1.5"
                    CornerRadius="20"
                    Padding="14,10"
                    Margin="0,0,20,0"
                    Effect="{StaticResource DropShadowEffect}">

                <Grid>
                    <!-- Latest bot message – right margin leaves room for the × -->
                    <TextBlock x:Name="LatestBubbleText"
                               Text="{Binding LatestBotMessage}"
                               Foreground="#E2E8F0"
                               FontSize="12.5"
                               TextWrapping="Wrap"
                               LineHeight="20"
                               MaxHeight="130"
                               Margin="0,0,20,0"/>

                    <!-- × close button – top-right inside bubble -->
                    <Button Command="{Binding ToggleChatCommand}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="#1E293B"
                            BorderThickness="0"
                            Cursor="Hand"
                            Padding="0"
                            Width="18" Height="18"
                            ToolTip="Schließen">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="9"/>
                            </Style>
                        </Button.Resources>
                        <materialDesign:PackIcon Kind="Close"
                                                  Width="11" Height="11"
                                                  Foreground="#64748B"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Speech-bubble tail: small downward triangle, centred-right -->
            <Path HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0,0,52,0"
                  Fill="#3B82F6">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="0,0" IsClosed="True">
                            <LineSegment Point="14,0"/>
                            <LineSegment Point="7,10"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
            <!-- Inner fill of tail (matches bubble background) -->
            <Path HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0,0,53,1"
                  Fill="#131920">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="0,0" IsClosed="True">
                            <LineSegment Point="12,0"/>
                            <LineSegment Point="6,8"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 1 – Brixl mascot (click = toggle speech bubble)
        ════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" HorizontalAlignment="Right" Margin="0,0,10,0">
            <Button Command="{Binding ToggleChatCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Padding="0"
                    ToolTip="Brixl – klicken um Sprechblase zu öffnen/schließen">
                <local:MascotAnimationView x:Name="MascotView"
                                           Width="100" Height="130"
                                           VerticalAlignment="Bottom"/>
            </Button>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 2 – Input bar:  ○  [text field]  ➡
        ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="#EE131920"
                BorderBrush="#334155"
                BorderThickness="1"
                CornerRadius="24"
                Padding="6,5"
                Effect="{StaticResource DropShadowEffect}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- ○ history  -->
                    <ColumnDefinition Width="*"/>      <!-- text input -->
                    <ColumnDefinition Width="Auto"/>   <!-- ➡ send     -->
                </Grid.ColumnDefinitions>

                <!-- ─ History / clock button (left circle) ─ -->
                <Button Grid.Column="0"
                        x:Name="HistoryBtn"
                        Click="OnHistoryClick"
                        Width="36" Height="36"
                        Background="#1E293B"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        Cursor="Hand"
                        ToolTip="Chatverlauf"
                        Padding="0"
                        Margin="2,0,6,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="18">
                    <materialDesign:PackIcon Kind="ClockOutline"
                                             Width="17" Height="17"
                                             Foreground="#60A5FA"/>
                </Button>

                <!-- ─ Text input ─ -->
                <TextBox x:Name="InputBox"
                         Grid.Column="1"
                         Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Frage oder Form beschreiben…"
                         materialDesign:HintAssist.Foreground="#64748B"
                         Style="{StaticResource MaterialDesignTextBox}"
                         Foreground="#F1F5F9"
                         Background="Transparent"
                         BorderThickness="0"
                         CaretBrush="#60A5FA"
                         Padding="4,8"
                         FontSize="12"
                         VerticalAlignment="Center"
                         TextWrapping="Wrap"
                         MaxHeight="56"
                         AcceptsReturn="False"
                         KeyDown="OnInputKeyDown"/>

                <!-- ─ Send button (right) ─ -->
                <Button Grid.Column="2"
                        Command="{Binding SendCommand}"
                        Width="36" Height="36"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Senden (Enter)"
                        Margin="6,0,2,0"
                        materialDesign:ButtonAssist.CornerRadius="18">
                    <Button.Style>
                        <Style TargetType="Button"
                               BasedOn="{StaticResource MaterialDesignRaisedButton}">
                            <Setter Property="Background" Value="#2563EB"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3B82F6"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#334155"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <materialDesign:PackIcon Kind="Send"
                                             Width="18" Height="18"
                                             Foreground="White"/>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             History popup – classic chat view (opens on clock click)
        ════════════════════════════════════════════════════════════ -->
        <Popup x:Name="HistoryPopup"
               PlacementTarget="{Binding ElementName=HistoryBtn}"
               Placement="Top"
               VerticalOffset="-8"
               HorizontalOffset="-8"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border Background="#F00F1419"
                    BorderBrush="#3B82F6"
                    BorderThickness="1.5"
                    CornerRadius="16"
                    MaxHeight="440"
                    Width="300"
                    Effect="{StaticResource DropShadowEffect}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- header  -->
                        <RowDefinition Height="*"/>     <!-- messages -->
                    </Grid.RowDefinitions>

                    <!-- ── Header ── -->
                    <Border Grid.Row="0"
                            Background="#1E293B"
                            CornerRadius="16,16,0,0"
                            Padding="14,10">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="Robot"
                                                          Width="16" Height="16"
                                                          Foreground="#60A5FA"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,7,0"/>
                                <TextBlock Text="Chatverlauf"
                                           Foreground="#60A5FA"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- × close header button -->
                            <Button Click="OnHistoryClick"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Padding="4"
                                    Width="26" Height="26"
                                    ToolTip="Schließen">
                                <materialDesign:PackIcon Kind="Close"
                                                          Width="14" Height="14"
                                                          Foreground="#64748B"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- ── Messages list ── -->
                    <ScrollViewer Grid.Row="1"
                                  x:Name="HistoryScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="10,8,10,8">
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">

                                        <!-- Bot bubble – left-aligned -->
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Left"
                                                    MaxWidth="248"
                                                    VerticalAlignment="Bottom">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <!-- Brixl avatar -->
                                            <Border Width="28" Height="28"
                                                    Background="#1D4ED8"
                                                    CornerRadius="14"
                                                    Margin="0,0,7,0"
                                                    VerticalAlignment="Bottom">
                                                <materialDesign:PackIcon Kind="Robot"
                                                                          Width="15" Height="15"
                                                                          Foreground="White"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                            </Border>
                                            <!-- Bubble -->
                                            <Border Background="#1A3A50"
                                                    CornerRadius="14,14,14,3"
                                                    Padding="11,8">
                                                <TextBlock Text="{Binding Text}"
                                                           Foreground="#CBD5E1"
                                                           FontSize="11.5"
                                                           TextWrapping="Wrap"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- User bubble – right-aligned -->
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    MaxWidth="248"
                                                    VerticalAlignment="Bottom">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <!-- Bubble -->
                                            <Border Background="#1D3461"
                                                    CornerRadius="14,14,3,14"
                                                    Padding="11,8">
                                                <TextBlock Text="{Binding Text}"
                                                           Foreground="#E2E8F0"
                                                           FontSize="11.5"
                                                           TextWrapping="Wrap"/>
                                            </Border>
                                            <!-- User avatar -->
                                            <Border Width="28" Height="28"
                                                    Background="#2563EB"
                                                    CornerRadius="14"
                                                    Margin="7,0,0,0"
                                                    VerticalAlignment="Bottom">
                                                <materialDesign:PackIcon Kind="Account"
                                                                          Width="15" Height="15"
                                                                          Foreground="White"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>

                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Popup>

    </Grid>
</UserControl>
