<UserControl x:Class="ThreeDBuilder.Views.ScadEditorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Background="{DynamicResource PanelBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" Background="#1A1F2E" BorderThickness="0,0,0,1" BorderBrush="#2D3748" Padding="4">
            <Button ToolTip="Vorschau (Ctrl+Shift+P)"
                    Command="{Binding ScadPreviewCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="{DynamicResource TextPrimary}"
                    Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Eye" Width="18" Height="18" Margin="0,0,6,0"/>
                    <TextBlock Text="Vorschau"/>
                </StackPanel>
            </Button>

            <Button ToolTip="Exportieren"
                    Command="{Binding ScadExportCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="{DynamicResource TextPrimary}"
                    Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Download" Width="18" Height="18" Margin="0,0,6,0"/>
                    <TextBlock Text="Exportieren"/>
                </StackPanel>
            </Button>

            <Separator Background="#2D3748" Margin="4,4"/>

            <Button ToolTip="Szene zu SCAD"
                    Command="{Binding ScadFromSceneCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="{DynamicResource TextPrimary}"
                    Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FileExport" Width="18" Height="18" Margin="0,0,6,0"/>
                    <TextBlock Text="Szene zu SCAD"/>
                </StackPanel>
            </Button>
        </ToolBar>

        <!-- Code Editor -->
        <TextBox Grid.Row="1"
                 x:Name="ScadCodeEditor"
                 Text="{Binding ScadCode, UpdateSourceTrigger=PropertyChanged}"
                 FontFamily="Consolas"
                 FontSize="11"
                 Background="#0F1419"
                 Foreground="#E0E0E0"
                 CaretBrush="#60A5FA"
                 BorderThickness="0"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 HorizontalScrollBarVisibility="Auto"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 Padding="8"/>

        <!-- Status/Error Message -->
        <Border Grid.Row="2"
                Background="#1A1F2E"
                BorderThickness="0,1,0,0"
                BorderBrush="#2D3748"
                Visibility="{Binding HasScadMessage, Converter={StaticResource BoolToVisibilityConverter}}"
                Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="120">
                <TextBlock Text="{Binding ScadMessage}"
                           Foreground="{Binding ScadMessageBrush}"
                           FontFamily="Consolas"
                           FontSize="11"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
