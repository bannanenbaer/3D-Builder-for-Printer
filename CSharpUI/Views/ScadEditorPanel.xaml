<UserControl x:Class="ThreeDBuilder.Views.ScadEditorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Toolbar -->
            <RowDefinition Height="*"/>      <!-- Editor -->
            <RowDefinition Height="Auto"/>   <!-- Error output -->
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" Background="#2D2D30">
            <Button Command="{Binding ScadPreviewCommand}"
                    ToolTip="{Binding T[btn_scad_preview]}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Play" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding T[btn_scad_preview]}"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button Command="{Binding ScadExportCommand}"
                    ToolTip="{Binding T[btn_scad_export]}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Download" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding T[btn_scad_export]}"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button Command="{Binding ScadFromSceneCommand}"
                    ToolTip="Szene → SCAD Code"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CodeBraces" Margin="0,0,4,0"/>
                    <TextBlock Text="Szene → SCAD"/>
                </StackPanel>
            </Button>
        </ToolBar>

        <!-- Code Editor -->
        <TextBox Grid.Row="1"
                 x:Name="ScadCodeEditor"
                 Text="{Binding ScadCode, UpdateSourceTrigger=PropertyChanged}"
                 FontFamily="Consolas, Courier New, monospace"
                 FontSize="13"
                 Background="#1E1E1E"
                 Foreground="#D4D4D4"
                 CaretBrush="White"
                 BorderThickness="0"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 HorizontalScrollBarVisibility="Auto"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 Padding="8"/>

        <!-- Error / status output -->
        <Border Grid.Row="2" Background="#1A1A2E" MinHeight="60" MaxHeight="120"
                Visibility="{Binding HasScadMessage,
                    Converter={StaticResource BoolToVisibilityConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding ScadMessage}"
                           Foreground="{Binding ScadMessageBrush}"
                           FontFamily="Consolas"
                           FontSize="11"
                           Padding="8"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
