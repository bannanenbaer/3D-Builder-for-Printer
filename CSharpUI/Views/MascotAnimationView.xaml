<UserControl x:Class="ThreeDBuilder.Views.MascotAnimationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Root grid — clips overflowing arm/tail animations -->
    <Grid Width="110" Height="140" ClipToBounds="False">

        <!-- ══ Mascot — entire body in a Canvas ══════════════════════════ -->
        <Canvas x:Name="MascotRoot" Width="110" Height="140">

            <!-- TranslateTransform on root for idle-float + walk movement -->
            <Canvas.RenderTransform>
                <TranslateTransform x:Name="RootTranslate" X="0" Y="0"/>
            </Canvas.RenderTransform>

            <!-- Shadow under feet -->
            <Ellipse Canvas.Left="20" Canvas.Top="130" Width="70" Height="10"
                     Fill="#33000000"/>

            <!-- ── TAIL ────────────────────────────────────────────────── -->
            <Path Canvas.Left="62" Canvas.Top="55"
                  Data="M 0,60 Q 30,50 35,25 Q 38,5 25,0"
                  Stroke="#20B2AA" StrokeThickness="14" Fill="Transparent"
                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Opacity="0.75"/>
            <Path Canvas.Left="62" Canvas.Top="55"
                  Data="M 0,60 Q 30,50 35,25 Q 38,5 25,0"
                  Stroke="#4FE5E5" StrokeThickness="8" Fill="Transparent"
                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Opacity="0.45"/>

            <!-- ── BODY ────────────────────────────────────────────────── -->
            <Ellipse Canvas.Left="15" Canvas.Top="60" Width="80" Height="80">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.35,0.3">
                        <GradientStop Color="#40D9D9" Offset="0"/>
                        <GradientStop Color="#20B2AA" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <!-- Fluff texture dots on body -->
            <Ellipse Canvas.Left="22" Canvas.Top="80"  Width="14" Height="14" Fill="#20B2AA" Opacity="0.35"/>
            <Ellipse Canvas.Left="72" Canvas.Top="86"  Width="16" Height="16" Fill="#20B2AA" Opacity="0.35"/>
            <Ellipse Canvas.Left="30" Canvas.Top="110" Width="14" Height="14" Fill="#20B2AA" Opacity="0.35"/>
            <Ellipse Canvas.Left="62" Canvas.Top="115" Width="13" Height="13" Fill="#20B2AA" Opacity="0.35"/>

            <!-- ── CHEST PANEL ─────────────────────────────────────────── -->
            <Rectangle Canvas.Left="40" Canvas.Top="82" Width="30" Height="34" Fill="#C0C0C0" RadiusX="3" RadiusY="3" Opacity="0.65"/>
            <Rectangle Canvas.Left="43" Canvas.Top="85" Width="24" Height="28" Fill="#808080" RadiusX="2" RadiusY="2"/>
            <!-- Panel lights -->
            <Ellipse Canvas.Left="47" Canvas.Top="89" Width="5" Height="5" Fill="#FF3333"/>
            <Ellipse Canvas.Left="57" Canvas.Top="89" Width="5" Height="5" Fill="#33FF33"/>
            <Ellipse Canvas.Left="52" Canvas.Top="97" Width="5" Height="5" Fill="#3399FF"/>
            <Ellipse Canvas.Left="47" Canvas.Top="104" Width="5" Height="5" Fill="#FFFF33"/>
            <Ellipse Canvas.Left="57" Canvas.Top="104" Width="5" Height="5" Fill="#FF33FF"/>

            <!-- ── LEFT ARM ────────────────────────────────────────────── -->
            <Line Canvas.Left="0" Canvas.Top="0" X1="28" Y1="88" X2="6" Y2="112"
                  Stroke="#20B2AA" StrokeThickness="11" StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
            <Ellipse Canvas.Left="-2" Canvas.Top="104" Width="14" Height="14" Fill="#C0C0C0"/>
            <Ellipse Canvas.Left="1"  Canvas.Top="107" Width="8"  Height="8"  Fill="#808080"/>
            <Ellipse Canvas.Left="-5" Canvas.Top="112" Width="16" Height="16" Fill="#20B2AA"/>

            <!-- ── RIGHT ARM (rotates for wave animation) ──────────────── -->
            <Canvas x:Name="RightArmCanvas" Canvas.Left="82" Canvas.Top="75">
                <Canvas.RenderTransform>
                    <RotateTransform x:Name="ArmRotate" Angle="0" CenterX="0" CenterY="0"/>
                </Canvas.RenderTransform>
                <Line X1="0" Y1="0" X2="22" Y2="-22"
                      Stroke="#20B2AA" StrokeThickness="11"
                      StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
                <Ellipse Canvas.Left="16" Canvas.Top="-30" Width="14" Height="14" Fill="#C0C0C0"/>
                <Ellipse Canvas.Left="19" Canvas.Top="-27" Width="8"  Height="8"  Fill="#808080"/>
                <Ellipse Canvas.Left="23" Canvas.Top="-38" Width="16" Height="16" Fill="#20B2AA"/>
            </Canvas>

            <!-- ── LEFT LEG ────────────────────────────────────────────── -->
            <Line Canvas.Left="0" Canvas.Top="0" X1="37" Y1="137" X2="33" Y2="155"
                  Stroke="#20B2AA" StrokeThickness="10" StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
            <Ellipse Canvas.Left="22" Canvas.Top="151" Width="22" Height="14" Fill="#1A8A7F"/>

            <!-- ── RIGHT LEG ───────────────────────────────────────────── -->
            <Line Canvas.Left="0" Canvas.Top="0" X1="73" Y1="137" X2="77" Y2="155"
                  Stroke="#20B2AA" StrokeThickness="10" StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
            <Ellipse Canvas.Left="66" Canvas.Top="151" Width="22" Height="14" Fill="#1A8A7F"/>

            <!-- ── HEAD ────────────────────────────────────────────────── -->
            <Ellipse Canvas.Left="13" Canvas.Top="10" Width="84" Height="74">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.38,0.35">
                        <GradientStop Color="#4FE5E5" Offset="0"/>
                        <GradientStop Color="#20B2AA" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Ear nubs (with metal accent) -->
            <Ellipse Canvas.Left="5"  Canvas.Top="12" Width="26" Height="38" Fill="#20B2AA"
                     RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform><RotateTransform Angle="-22"/></Ellipse.RenderTransform>
            </Ellipse>
            <Rectangle Canvas.Left="10" Canvas.Top="18" Width="9" Height="20" Fill="#C0C0C0" RadiusX="2" RadiusY="2"
                       RenderTransformOrigin="0.5,0.5">
                <Rectangle.RenderTransform><RotateTransform Angle="-22"/></Rectangle.RenderTransform>
            </Rectangle>
            <Ellipse Canvas.Left="79" Canvas.Top="12" Width="26" Height="38" Fill="#20B2AA"
                     RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform><RotateTransform Angle="22"/></Ellipse.RenderTransform>
            </Ellipse>
            <Rectangle Canvas.Left="91" Canvas.Top="18" Width="9" Height="20" Fill="#C0C0C0" RadiusX="2" RadiusY="2"
                       RenderTransformOrigin="0.5,0.5">
                <Rectangle.RenderTransform><RotateTransform Angle="22"/></Rectangle.RenderTransform>
            </Rectangle>

            <!-- ── EYES ────────────────────────────────────────────────── -->
            <!-- Left eye -->
            <Ellipse Canvas.Left="24" Canvas.Top="26" Width="22" Height="22" Fill="White"/>
            <Ellipse x:Name="LeftPupil" Canvas.Left="30" Canvas.Top="31" Width="12" Height="12" Fill="#1A1A1A"/>
            <Ellipse Canvas.Left="36" Canvas.Top="29" Width="5"  Height="5"  Fill="White"/>
            <!-- Right eye -->
            <Ellipse Canvas.Left="64" Canvas.Top="26" Width="22" Height="22" Fill="White"/>
            <Ellipse x:Name="RightPupil" Canvas.Left="68" Canvas.Top="31" Width="12" Height="12" Fill="#1A1A1A"/>
            <Ellipse Canvas.Left="72" Canvas.Top="29" Width="5"  Height="5"  Fill="White"/>

            <!-- Eyebrows -->
            <Path Canvas.Left="22" Canvas.Top="18"
                  Data="M 4,6 Q 11,1 20,6"
                  Stroke="#1A8A7F" StrokeThickness="2.5" Fill="Transparent"
                  StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
            <Path Canvas.Left="62" Canvas.Top="18"
                  Data="M 4,6 Q 11,1 20,6"
                  Stroke="#1A8A7F" StrokeThickness="2.5" Fill="Transparent"
                  StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>

            <!-- Nose -->
            <Ellipse Canvas.Left="49" Canvas.Top="52" Width="12" Height="10" Fill="#1A8A7F"/>

            <!-- Mouth smile -->
            <Path Canvas.Left="36" Canvas.Top="60"
                  Data="M 0,0 Q 17,12 34,0"
                  Stroke="#1A1A1A" StrokeThickness="2.5" Fill="Transparent"
                  StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
            <!-- Tongue -->
            <Ellipse Canvas.Left="50" Canvas.Top="66" Width="10" Height="8" Fill="#FF69B4"/>

            <!-- Blush marks -->
            <Ellipse Canvas.Left="15" Canvas.Top="55" Width="14" Height="10" Fill="#FF69B4" Opacity="0.35"/>
            <Ellipse Canvas.Left="81" Canvas.Top="55" Width="14" Height="10" Fill="#FF69B4" Opacity="0.35"/>

            <!-- Sparkle dots -->
            <Ellipse Canvas.Left="4"   Canvas.Top="5"   Width="5" Height="5" Fill="#FFD700" Opacity="0.8"/>
            <Ellipse Canvas.Left="100" Canvas.Top="10"  Width="4" Height="4" Fill="#FFD700" Opacity="0.8"/>
            <Ellipse Canvas.Left="2"   Canvas.Top="75"  Width="3" Height="3" Fill="#FFD700" Opacity="0.6"/>
            <Ellipse Canvas.Left="104" Canvas.Top="70"  Width="3" Height="3" Fill="#FFD700" Opacity="0.6"/>
        </Canvas>

        <!-- ══ Animation storyboards ══════════════════════════════════════ -->
        <Grid.Resources>

            <!-- Idle float (bobs up and down gently) — plays always -->
            <Storyboard x:Key="IdleFloat" RepeatBehavior="Forever" AutoReverse="True">
                <DoubleAnimation Storyboard.TargetName="RootTranslate"
                                 Storyboard.TargetProperty="Y"
                                 From="0" To="-7" Duration="0:0:1.8"
                                 AccelerationRatio="0.4" DecelerationRatio="0.4"/>
            </Storyboard>

            <!-- Arm wave (right arm rotates back and forth) -->
            <Storyboard x:Key="WaveAnimation" RepeatBehavior="Forever" AutoReverse="True">
                <DoubleAnimation Storyboard.TargetName="ArmRotate"
                                 Storyboard.TargetProperty="Angle"
                                 From="-15" To="30" Duration="0:0:0.4"/>
            </Storyboard>

            <!-- Walk (slides left/right) -->
            <Storyboard x:Key="WalkAnimation" RepeatBehavior="Forever" AutoReverse="True">
                <DoubleAnimation Storyboard.TargetName="RootTranslate"
                                 Storyboard.TargetProperty="X"
                                 From="0" To="40" Duration="0:0:1.2"
                                 AccelerationRatio="0.4" DecelerationRatio="0.4"/>
            </Storyboard>

            <!-- Blink (pupils briefly vanish) -->
            <Storyboard x:Key="BlinkAnimation" RepeatBehavior="Forever">
                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="LeftPupil"
                                               Storyboard.TargetProperty="Visibility"
                                               BeginTime="0:0:3">
                    <DiscreteObjectKeyFrame KeyTime="0:0:0"   Value="{x:Static Visibility.Visible}"/>
                    <DiscreteObjectKeyFrame KeyTime="0:0:0.08" Value="{x:Static Visibility.Hidden}"/>
                    <DiscreteObjectKeyFrame KeyTime="0:0:0.17" Value="{x:Static Visibility.Visible}"/>
                    <DiscreteObjectKeyFrame KeyTime="0:0:4"   Value="{x:Static Visibility.Visible}"/>
                </ObjectAnimationUsingKeyFrames>
                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RightPupil"
                                               Storyboard.TargetProperty="Visibility"
                                               BeginTime="0:0:3">
                    <DiscreteObjectKeyFrame KeyTime="0:0:0"   Value="{x:Static Visibility.Visible}"/>
                    <DiscreteObjectKeyFrame KeyTime="0:0:0.08" Value="{x:Static Visibility.Hidden}"/>
                    <DiscreteObjectKeyFrame KeyTime="0:0:0.17" Value="{x:Static Visibility.Visible}"/>
                    <DiscreteObjectKeyFrame KeyTime="0:0:4"   Value="{x:Static Visibility.Visible}"/>
                </ObjectAnimationUsingKeyFrames>
            </Storyboard>

            <!-- Hammer animation (arm bobs down fast = hammering) -->
            <Storyboard x:Key="HammerAnimation" RepeatBehavior="Forever" AutoReverse="True">
                <DoubleAnimation Storyboard.TargetName="ArmRotate"
                                 Storyboard.TargetProperty="Angle"
                                 From="0" To="60" Duration="0:0:0.15"/>
                <DoubleAnimation Storyboard.TargetName="RootTranslate"
                                 Storyboard.TargetProperty="X"
                                 From="0" To="35" Duration="0:0:1.5"
                                 AccelerationRatio="0.4" DecelerationRatio="0.4"/>
            </Storyboard>

            <!-- Brush animation (arm sweeps gently) -->
            <Storyboard x:Key="BrushAnimation" RepeatBehavior="Forever" AutoReverse="True">
                <DoubleAnimation Storyboard.TargetName="ArmRotate"
                                 Storyboard.TargetProperty="Angle"
                                 From="-10" To="20" Duration="0:0:0.6"/>
                <DoubleAnimation Storyboard.TargetName="RootTranslate"
                                 Storyboard.TargetProperty="X"
                                 From="0" To="25" Duration="0:0:1.8"
                                 AccelerationRatio="0.4" DecelerationRatio="0.4"/>
            </Storyboard>

            <!-- Tape animation (arm circles) -->
            <Storyboard x:Key="TapeAnimation" RepeatBehavior="Forever" AutoReverse="True">
                <DoubleAnimation Storyboard.TargetName="ArmRotate"
                                 Storyboard.TargetProperty="Angle"
                                 From="-20" To="40" Duration="0:0:0.5"/>
                <DoubleAnimation Storyboard.TargetName="RootTranslate"
                                 Storyboard.TargetProperty="X"
                                 From="0" To="30" Duration="0:0:1.6"/>
            </Storyboard>

        </Grid.Resources>
    </Grid>
</UserControl>
