<UserControl x:Class="ThreeDBuilder.Views.MascotAnimationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══ Animation storyboards — must live in UserControl.Resources so
         code-behind can find them via this.Resources["key"]            ══ -->
    <UserControl.Resources>

        <!-- Idle float (bobs up and down gently) — plays always -->
        <Storyboard x:Key="IdleFloat" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="RootTranslate"
                             Storyboard.TargetProperty="Y"
                             From="0" To="-9" Duration="0:0:1.8"
                             AccelerationRatio="0.4" DecelerationRatio="0.4"/>
        </Storyboard>

        <!-- Arm wave (right arm rotates back and forth) -->
        <Storyboard x:Key="WaveAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="ArmRotate"
                             Storyboard.TargetProperty="Angle"
                             From="-15" To="35" Duration="0:0:0.4"/>
        </Storyboard>

        <!-- Walk (slides left/right) -->
        <Storyboard x:Key="WalkAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="RootTranslate"
                             Storyboard.TargetProperty="X"
                             From="0" To="40" Duration="0:0:1.2"
                             AccelerationRatio="0.4" DecelerationRatio="0.4"/>
        </Storyboard>

        <!-- Blink (pupils briefly vanish) -->
        <Storyboard x:Key="BlinkAnimation" RepeatBehavior="Forever">
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="LeftPupil"
                                           Storyboard.TargetProperty="Visibility"
                                           BeginTime="0:0:3">
                <DiscreteObjectKeyFrame KeyTime="0:0:0"    Value="{x:Static Visibility.Visible}"/>
                <DiscreteObjectKeyFrame KeyTime="0:0:0.08" Value="{x:Static Visibility.Hidden}"/>
                <DiscreteObjectKeyFrame KeyTime="0:0:0.17" Value="{x:Static Visibility.Visible}"/>
                <DiscreteObjectKeyFrame KeyTime="0:0:4"    Value="{x:Static Visibility.Visible}"/>
            </ObjectAnimationUsingKeyFrames>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RightPupil"
                                           Storyboard.TargetProperty="Visibility"
                                           BeginTime="0:0:3">
                <DiscreteObjectKeyFrame KeyTime="0:0:0"    Value="{x:Static Visibility.Visible}"/>
                <DiscreteObjectKeyFrame KeyTime="0:0:0.08" Value="{x:Static Visibility.Hidden}"/>
                <DiscreteObjectKeyFrame KeyTime="0:0:0.17" Value="{x:Static Visibility.Visible}"/>
                <DiscreteObjectKeyFrame KeyTime="0:0:4"    Value="{x:Static Visibility.Visible}"/>
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Hammer animation (arm bobs down fast = hammering) -->
        <Storyboard x:Key="HammerAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="ArmRotate"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="65" Duration="0:0:0.15"/>
            <DoubleAnimation Storyboard.TargetName="RootTranslate"
                             Storyboard.TargetProperty="X"
                             From="0" To="35" Duration="0:0:1.5"
                             AccelerationRatio="0.4" DecelerationRatio="0.4"/>
        </Storyboard>

        <!-- Brush animation (arm sweeps gently) -->
        <Storyboard x:Key="BrushAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="ArmRotate"
                             Storyboard.TargetProperty="Angle"
                             From="-10" To="25" Duration="0:0:0.6"/>
            <DoubleAnimation Storyboard.TargetName="RootTranslate"
                             Storyboard.TargetProperty="X"
                             From="0" To="25" Duration="0:0:1.8"
                             AccelerationRatio="0.4" DecelerationRatio="0.4"/>
        </Storyboard>

        <!-- Tape animation (arm circles) -->
        <Storyboard x:Key="TapeAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="ArmRotate"
                             Storyboard.TargetProperty="Angle"
                             From="-20" To="45" Duration="0:0:0.5"/>
            <DoubleAnimation Storyboard.TargetName="RootTranslate"
                             Storyboard.TargetProperty="X"
                             From="0" To="30" Duration="0:0:1.6"/>
        </Storyboard>

        <!-- Tail swing animation -->
        <Storyboard x:Key="SwingAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="TailRotate"
                             Storyboard.TargetProperty="Angle"
                             From="-18" To="18" Duration="0:0:0.7"
                             AccelerationRatio="0.3" DecelerationRatio="0.3"/>
        </Storyboard>

        <!-- Jump animation — Brixl hüpft fröhlich -->
        <Storyboard x:Key="JumpAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="RootTranslate"
                             Storyboard.TargetProperty="Y"
                             From="0" To="-30" Duration="0:0:0.35"
                             AccelerationRatio="0.5" DecelerationRatio="0.5"/>
        </Storyboard>

        <!-- Excited animation — beide Arme hoch + hüpfen -->
        <Storyboard x:Key="ExcitedAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="ArmRotate"
                             Storyboard.TargetProperty="Angle"
                             From="-40" To="-70" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="LeftArmRotate"
                             Storyboard.TargetProperty="Angle"
                             From="20" To="60" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="RootTranslate"
                             Storyboard.TargetProperty="Y"
                             From="0" To="-22" Duration="0:0:0.3"
                             AccelerationRatio="0.4" DecelerationRatio="0.4"/>
        </Storyboard>

        <!-- Thinking animation — langsames Wippen -->
        <Storyboard x:Key="ThinkingAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="ArmRotate"
                             Storyboard.TargetProperty="Angle"
                             From="-30" To="-50" Duration="0:0:1.2"/>
            <DoubleAnimation Storyboard.TargetName="RootTranslate"
                             Storyboard.TargetProperty="Y"
                             From="0" To="-5" Duration="0:0:1.5"
                             AccelerationRatio="0.4" DecelerationRatio="0.4"/>
        </Storyboard>

        <!-- Happy animation — Tanzbewegung (Hüpfen + Armwedeln) -->
        <Storyboard x:Key="HappyAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="ArmRotate"
                             Storyboard.TargetProperty="Angle"
                             From="-20" To="40" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetName="LeftArmRotate"
                             Storyboard.TargetProperty="Angle"
                             From="10" To="-30" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetName="RootTranslate"
                             Storyboard.TargetProperty="Y"
                             From="0" To="-18" Duration="0:0:0.4"
                             AccelerationRatio="0.3" DecelerationRatio="0.3"/>
            <DoubleAnimation Storyboard.TargetName="RootTranslate"
                             Storyboard.TargetProperty="X"
                             From="0" To="15" Duration="0:0:0.8"
                             AccelerationRatio="0.3" DecelerationRatio="0.3"/>
        </Storyboard>

    </UserControl.Resources>

    <!-- Root grid — clips overflowing arm/tail animations -->
    <Grid Width="160" Height="200" ClipToBounds="False">

        <!-- ══ Mascot — entire body in a Canvas ══════════════════════════ -->
        <Canvas x:Name="MascotRoot" Width="160" Height="200">

            <!-- TranslateTransform on root for idle-float + walk movement -->
            <Canvas.RenderTransform>
                <TranslateTransform x:Name="RootTranslate" X="0" Y="0"/>
            </Canvas.RenderTransform>

            <!-- Shadow under feet -->
            <Ellipse Canvas.Left="30" Canvas.Top="188" Width="100" Height="12"
                     Fill="#33000000"/>

            <!-- ── TAIL ────────────────────────────────────────────────── -->
            <Canvas x:Name="TailCanvas" Canvas.Left="88" Canvas.Top="80">
                <Canvas.RenderTransform>
                    <RotateTransform x:Name="TailRotate" Angle="0" CenterX="0" CenterY="60"/>
                </Canvas.RenderTransform>
                <Path Data="M 0,60 Q 38,50 44,28 Q 48,5 30,0"
                      Stroke="#20B2AA" StrokeThickness="18" Fill="Transparent"
                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Opacity="0.75"/>
                <Path Data="M 0,60 Q 38,50 44,28 Q 48,5 30,0"
                      Stroke="#4FE5E5" StrokeThickness="10" Fill="Transparent"
                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Opacity="0.45"/>
            </Canvas>

            <!-- ── BODY ────────────────────────────────────────────────── -->
            <Ellipse Canvas.Left="20" Canvas.Top="88" Width="120" Height="110">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.35,0.3">
                        <GradientStop Color="#40D9D9" Offset="0"/>
                        <GradientStop Color="#20B2AA" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <!-- Fluff texture dots on body -->
            <Ellipse Canvas.Left="28" Canvas.Top="112"  Width="18" Height="18" Fill="#20B2AA" Opacity="0.35"/>
            <Ellipse Canvas.Left="108" Canvas.Top="120"  Width="20" Height="20" Fill="#20B2AA" Opacity="0.35"/>
            <Ellipse Canvas.Left="38" Canvas.Top="158" Width="18" Height="18" Fill="#20B2AA" Opacity="0.35"/>
            <Ellipse Canvas.Left="96" Canvas.Top="165" Width="16" Height="16" Fill="#20B2AA" Opacity="0.35"/>

            <!-- ── HEART on BELLY ──────────────────────────────────────── -->
            <Canvas Canvas.Left="56" Canvas.Top="118">
                <!-- Heart shape using two ellipses + path -->
                <Ellipse Canvas.Left="0"  Canvas.Top="0" Width="20" Height="20"
                         Fill="#FF69B4" Opacity="0.85"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform><RotateTransform Angle="-45"/></Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Canvas.Left="14" Canvas.Top="0" Width="20" Height="20"
                         Fill="#FF69B4" Opacity="0.85"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform><RotateTransform Angle="-45"/></Ellipse.RenderTransform>
                </Ellipse>
                <Path Data="M 0,10 L 17,30 L 34,10"
                      Fill="#FF69B4" Opacity="0.85"
                      StrokeThickness="0"/>
            </Canvas>

            <!-- ── LEFT ARM ────────────────────────────────────────────── -->
            <Canvas x:Name="LeftArmCanvas" Canvas.Left="0" Canvas.Top="108">
                <Canvas.RenderTransform>
                    <RotateTransform x:Name="LeftArmRotate" Angle="0" CenterX="28" CenterY="0"/>
                </Canvas.RenderTransform>
                <Line X1="28" Y1="0" X2="6" Y2="30"
                      Stroke="#20B2AA" StrokeThickness="14"
                      StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
                <Ellipse Canvas.Left="-4" Canvas.Top="22" Width="18" Height="18" Fill="#C0C0C0"/>
                <Ellipse Canvas.Left="0"  Canvas.Top="26" Width="10" Height="10" Fill="#808080"/>
                <Ellipse Canvas.Left="-8" Canvas.Top="32" Width="20" Height="20" Fill="#20B2AA"/>
            </Canvas>

            <!-- ── RIGHT ARM (rotates for wave animation) ──────────────── -->
            <Canvas x:Name="RightArmCanvas" Canvas.Left="118" Canvas.Top="104">
                <Canvas.RenderTransform>
                    <RotateTransform x:Name="ArmRotate" Angle="0" CenterX="0" CenterY="0"/>
                </Canvas.RenderTransform>
                <Line X1="0" Y1="0" X2="30" Y2="-30"
                      Stroke="#20B2AA" StrokeThickness="14"
                      StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
                <Ellipse Canvas.Left="22" Canvas.Top="-42" Width="18" Height="18" Fill="#C0C0C0"/>
                <Ellipse Canvas.Left="26" Canvas.Top="-38" Width="10" Height="10" Fill="#808080"/>
                <Ellipse Canvas.Left="30" Canvas.Top="-52" Width="20" Height="20" Fill="#20B2AA"/>
            </Canvas>

            <!-- ── LEFT LEG ────────────────────────────────────────────── -->
            <Line Canvas.Left="0" Canvas.Top="0" X1="55" Y1="194" X2="48" Y2="216"
                  Stroke="#20B2AA" StrokeThickness="14" StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
            <Ellipse Canvas.Left="32" Canvas.Top="212" Width="28" Height="18" Fill="#1A8A7F"/>

            <!-- ── RIGHT LEG ───────────────────────────────────────────── -->
            <Line Canvas.Left="0" Canvas.Top="0" X1="105" Y1="194" X2="112" Y2="216"
                  Stroke="#20B2AA" StrokeThickness="14" StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
            <Ellipse Canvas.Left="100" Canvas.Top="212" Width="28" Height="18" Fill="#1A8A7F"/>

            <!-- ── HEAD ────────────────────────────────────────────────── -->
            <Ellipse Canvas.Left="14" Canvas.Top="8" Width="132" Height="108">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.38,0.35">
                        <GradientStop Color="#4FE5E5" Offset="0"/>
                        <GradientStop Color="#20B2AA" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Ear nubs (with metal accent) -->
            <Ellipse Canvas.Left="2" Canvas.Top="12" Width="36" Height="52" Fill="#20B2AA"
                     RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform><RotateTransform Angle="-22"/></Ellipse.RenderTransform>
            </Ellipse>
            <Rectangle Canvas.Left="10" Canvas.Top="20" Width="12" Height="28" Fill="#C0C0C0" RadiusX="2" RadiusY="2"
                       RenderTransformOrigin="0.5,0.5">
                <Rectangle.RenderTransform><RotateTransform Angle="-22"/></Rectangle.RenderTransform>
            </Rectangle>
            <Ellipse Canvas.Left="122" Canvas.Top="12" Width="36" Height="52" Fill="#20B2AA"
                     RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform><RotateTransform Angle="22"/></Ellipse.RenderTransform>
            </Ellipse>
            <Rectangle Canvas.Left="138" Canvas.Top="20" Width="12" Height="28" Fill="#C0C0C0" RadiusX="2" RadiusY="2"
                       RenderTransformOrigin="0.5,0.5">
                <Rectangle.RenderTransform><RotateTransform Angle="22"/></Rectangle.RenderTransform>
            </Rectangle>

            <!-- ── EYES ────────────────────────────────────────────────── -->
            <!-- Left eye -->
            <Ellipse Canvas.Left="30" Canvas.Top="34" Width="34" Height="34" Fill="White">
                <Ellipse.Effect>
                    <DropShadowEffect Color="#40D9D9" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse x:Name="LeftPupil" Canvas.Left="40" Canvas.Top="42" Width="16" Height="16" Fill="#1A1A1A"/>
            <Ellipse Canvas.Left="50" Canvas.Top="38" Width="7" Height="7" Fill="White"/>
            <!-- Right eye -->
            <Ellipse Canvas.Left="96" Canvas.Top="34" Width="34" Height="34" Fill="White">
                <Ellipse.Effect>
                    <DropShadowEffect Color="#40D9D9" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse x:Name="RightPupil" Canvas.Left="104" Canvas.Top="42" Width="16" Height="16" Fill="#1A1A1A"/>
            <Ellipse Canvas.Left="112" Canvas.Top="38" Width="7" Height="7" Fill="White"/>

            <!-- Eyebrows -->
            <Path Canvas.Left="28" Canvas.Top="24"
                  Data="M 4,8 Q 15,1 28,8"
                  Stroke="#1A8A7F" StrokeThickness="3" Fill="Transparent"
                  StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
            <Path Canvas.Left="94" Canvas.Top="24"
                  Data="M 4,8 Q 15,1 28,8"
                  Stroke="#1A8A7F" StrokeThickness="3" Fill="Transparent"
                  StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>

            <!-- Nose -->
            <Ellipse Canvas.Left="72" Canvas.Top="74" Width="16" Height="13" Fill="#1A8A7F"/>

            <!-- Mouth smile -->
            <Path Canvas.Left="52" Canvas.Top="85"
                  Data="M 0,0 Q 24,16 48,0"
                  Stroke="#1A1A1A" StrokeThickness="3" Fill="Transparent"
                  StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
            <!-- Tongue -->
            <Ellipse Canvas.Left="72" Canvas.Top="94" Width="16" Height="12" Fill="#FF69B4"/>

            <!-- Blush marks (bigger) -->
            <Ellipse Canvas.Left="16" Canvas.Top="76" Width="22" Height="16" Fill="#FF69B4" Opacity="0.4"/>
            <Ellipse Canvas.Left="122" Canvas.Top="76" Width="22" Height="16" Fill="#FF69B4" Opacity="0.4"/>

            <!-- Sparkle dots -->
            <Ellipse Canvas.Left="4"   Canvas.Top="5"   Width="7" Height="7" Fill="#FFD700" Opacity="0.8"/>
            <Ellipse Canvas.Left="148" Canvas.Top="12"  Width="6" Height="6" Fill="#FFD700" Opacity="0.8"/>
            <Ellipse Canvas.Left="2"   Canvas.Top="108" Width="5" Height="5" Fill="#FFD700" Opacity="0.6"/>
            <Ellipse Canvas.Left="152" Canvas.Top="100" Width="4" Height="4" Fill="#FFD700" Opacity="0.6"/>
        </Canvas>

    </Grid>
</UserControl>
