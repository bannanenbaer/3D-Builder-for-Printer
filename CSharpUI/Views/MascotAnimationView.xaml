<UserControl x:Class="ThreeDBuilder.Views.MascotAnimationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Background="Transparent" Height="120">
        <!-- Mascot Character -->
        <Canvas x:Name="MascotCanvas" Background="Transparent">
            
            <!-- Mascot Body (simplified cute character) -->
            <Ellipse Canvas.Left="30" Canvas.Top="20" Width="50" Height="60" 
                     Fill="#20B2AA" Stroke="#1A8A7F" StrokeThickness="2"/>
            
            <!-- Mascot Head -->
            <Ellipse Canvas.Left="35" Canvas.Top="10" Width="40" Height="40" 
                     Fill="#20B2AA" Stroke="#1A8A7F" StrokeThickness="2"/>
            
            <!-- Eyes -->
            <Ellipse Canvas.Left="42" Canvas.Top="18" Width="8" Height="8" Fill="White"/>
            <Ellipse Canvas.Left="58" Canvas.Top="18" Width="8" Height="8" Fill="White"/>
            
            <!-- Pupils (animated) -->
            <Ellipse x:Name="LeftPupil" Canvas.Left="45" Canvas.Top="20" Width="4" Height="4" Fill="Black"/>
            <Ellipse x:Name="RightPupil" Canvas.Left="61" Canvas.Top="20" Width="4" Height="4" Fill="Black"/>
            
            <!-- Smile -->
            <Path Canvas.Left="45" Canvas.Top="32" Width="20" Height="8"
                  Stroke="Black" StrokeThickness="1.5" Fill="Transparent"
                  Data="M 0,0 Q 10,8 20,0"/>
            
            <!-- Left Arm -->
            <Line X1="30" Y1="50" X2="15" Y2="60" Stroke="#20B2AA" StrokeThickness="3"/>
            
            <!-- Right Arm (holding tool) -->
            <Line X1="80" Y1="50" X2="95" Y2="60" Stroke="#20B2AA" StrokeThickness="3"/>
            
            <!-- Tool Container (changes based on animation phase) -->
            <Canvas x:Name="ToolCanvas" Canvas.Left="95" Canvas.Top="55" Width="40" Height="30">
                
                <!-- Brush Tool -->
                <Canvas x:Name="BrushTool" Visibility="Collapsed">
                    <!-- Handle -->
                    <Rectangle Width="4" Height="20" Fill="#8B4513"/>
                    <!-- Bristles -->
                    <Ellipse Canvas.Left="-2" Canvas.Top="-8" Width="8" Height="8" Fill="#FF69B4"/>
                    <Ellipse Canvas.Left="-1" Canvas.Top="-6" Width="6" Height="6" Fill="#FF1493"/>
                </Canvas>
                
                <!-- Hammer Tool -->
                <Canvas x:Name="HammerTool" Visibility="Collapsed">
                    <!-- Handle -->
                    <Rectangle Width="3" Height="18" Fill="#8B4513"/>
                    <!-- Head -->
                    <Rectangle Canvas.Left="-3" Canvas.Top="-6" Width="9" Height="8" Fill="#696969"/>
                    <!-- Face -->
                    <Rectangle Canvas.Left="-2" Canvas.Top="-5" Width="7" Height="6" Fill="#808080"/>
                </Canvas>
                
                <!-- Tape Tool -->
                <Canvas x:Name="TapeTool" Visibility="Collapsed">
                    <!-- Roll -->
                    <Ellipse Width="12" Height="12" Fill="#FFD700"/>
                    <Ellipse Canvas.Left="2" Canvas.Top="2" Width="8" Height="8" Fill="#FFA500"/>
                    <!-- Tape strip -->
                    <Rectangle Canvas.Left="12" Canvas.Top="4" Width="15" Height="4" Fill="#FFD700"/>
                </Canvas>
            </Canvas>
            
            <!-- Legs -->
            <Line X1="45" Y1="80" X2="40" Y2="95" Stroke="#20B2AA" StrokeThickness="3"/>
            <Line X1="65" Y1="80" X2="70" Y2="95" Stroke="#20B2AA" StrokeThickness="3"/>
            
            <!-- Feet -->
            <Ellipse Canvas.Left="35" Canvas.Top="95" Width="10" Height="6" Fill="#1A8A7F"/>
            <Ellipse Canvas.Left="65" Canvas.Top="95" Width="10" Height="6" Fill="#1A8A7F"/>
        </Canvas>

        <!-- Animation Storyboards -->
        <Grid.Resources>
            <!-- Brush Animation -->
            <Storyboard x:Key="BrushAnimation" RepeatBehavior="Forever">
                <!-- Move right arm with brush -->
                <DoubleAnimation Storyboard.TargetName="MascotCanvas" 
                                 Storyboard.TargetProperty="(Canvas.Left)"
                                 From="0" To="30" Duration="0:0:1.5" 
                                 RepeatBehavior="Forever" AutoReverse="True"/>
                
                <!-- Brush painting motion -->
                <DoubleAnimation Storyboard.TargetName="BrushTool" 
                                 Storyboard.TargetProperty="(Canvas.Top)"
                                 From="0" To="10" Duration="0:0:0.3" 
                                 RepeatBehavior="Forever" AutoReverse="True"/>
                
                <!-- Rotate brush -->
                <DoubleAnimation Storyboard.TargetName="BrushTool" 
                                 Storyboard.TargetProperty="(Canvas.Left)"
                                 From="0" To="5" Duration="0:0:0.3" 
                                 RepeatBehavior="Forever" AutoReverse="True"/>
            </Storyboard>

            <!-- Hammer Animation -->
            <Storyboard x:Key="HammerAnimation" RepeatBehavior="Forever">
                <!-- Move to object -->
                <DoubleAnimation Storyboard.TargetName="MascotCanvas" 
                                 Storyboard.TargetProperty="(Canvas.Left)"
                                 From="0" To="40" Duration="0:0:2" 
                                 RepeatBehavior="Forever" AutoReverse="True"/>
                
                <!-- Hammer strike motion -->
                <DoubleAnimation Storyboard.TargetName="HammerTool" 
                                 Storyboard.TargetProperty="(Canvas.Top)"
                                 From="0" To="15" Duration="0:0:0.2" 
                                 RepeatBehavior="Forever" AutoReverse="True"/>
                
                <!-- Hammer rotation -->
                <DoubleAnimation Storyboard.TargetName="HammerTool" 
                                 Storyboard.TargetProperty="(Canvas.Left)"
                                 From="0" To="8" Duration="0:0:0.2" 
                                 RepeatBehavior="Forever" AutoReverse="True"/>
            </Storyboard>

            <!-- Tape Animation -->
            <Storyboard x:Key="TapeAnimation" RepeatBehavior="Forever">
                <!-- Move around object -->
                <DoubleAnimation Storyboard.TargetName="MascotCanvas" 
                                 Storyboard.TargetProperty="(Canvas.Left)"
                                 From="0" To="35" Duration="0:0:1.8" 
                                 RepeatBehavior="Forever" AutoReverse="True"/>
                
                <!-- Tape wrapping motion -->
                <DoubleAnimation Storyboard.TargetName="TapeTool" 
                                 Storyboard.TargetProperty="(Canvas.Top)"
                                 From="0" To="8" Duration="0:0:0.4" 
                                 RepeatBehavior="Forever" AutoReverse="True"/>
                
                <!-- Tape roll rotation -->
                <DoubleAnimation Storyboard.TargetName="TapeTool" 
                                 Storyboard.TargetProperty="(Canvas.Left)"
                                 From="0" To="10" Duration="0:0:0.4" 
                                 RepeatBehavior="Forever" AutoReverse="True"/>
            </Storyboard>

            <!-- Walk Animation -->
            <Storyboard x:Key="WalkAnimation" RepeatBehavior="Forever">
                <!-- Walking motion -->
                <DoubleAnimation Storyboard.TargetName="MascotCanvas" 
                                 Storyboard.TargetProperty="(Canvas.Left)"
                                 From="0" To="50" Duration="0:0:2" 
                                 RepeatBehavior="Forever" AutoReverse="True"/>
            </Storyboard>
        </Canvas.Resources>
    </Grid>
</UserControl>
