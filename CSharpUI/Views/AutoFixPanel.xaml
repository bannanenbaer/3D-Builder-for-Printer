<UserControl x:Class="ThreeDBuilder.Views.AutoFixPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:ThreeDBuilder.Views">

    <StackPanel Margin="8">

        <!-- ── Objekt-Auswahl ────────────────────────────────────────── -->
        <TextBlock Style="{StaticResource SectionHeader}"
                   Text="Zu optimierendes Objekt"/>

        <ComboBox ItemsSource="{Binding AvailableObjects}"
                  SelectedItem="{Binding SelectedObjectForOptimization}"
                  DisplayMemberPath="Name"
                  Background="#1F2937"
                  Foreground="{StaticResource TextPrimary}"
                  BorderBrush="#374151"
                  Margin="4,4"/>

        <TextBlock Text="Wähle ein Objekt aus der Szene, um nur dieses zu optimieren"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="9"
                   Margin="4,2"/>

        <TextBlock Text="{Binding SelectedObjectInfo}"
                   Foreground="#60A5FA"
                   FontSize="9"
                   FontWeight="SemiBold"
                   Margin="4,2"/>

        <Separator Style="{StaticResource PanelSeparator}"/>

        <!-- ── Undo/Redo Buttons ──────────────────────────────────────── -->
        <TextBlock Style="{StaticResource SectionHeader}"
                   Text="Bearbeitungsverlauf"/>

        <Grid Margin="4,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Undo Button -->
            <Button Grid.Column="0"
                    Command="{Binding UndoCommand}"
                    IsEnabled="{Binding CanUndo}"
                    Style="{StaticResource ActionButton}"
                    Margin="0,0,2,0"
                    ToolTip="{Binding UndoDescription}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="Undo" Margin="0,0,6,0"/>
                    <TextBlock Text="Zurück"/>
                </StackPanel>
            </Button>

            <!-- Redo Button -->
            <Button Grid.Column="1"
                    Command="{Binding RedoCommand}"
                    IsEnabled="{Binding CanRedo}"
                    Style="{StaticResource ActionButton}"
                    Margin="2,0,0,0"
                    ToolTip="{Binding RedoDescription}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="Redo" Margin="0,0,6,0"/>
                    <TextBlock Text="Vorwärts"/>
                </StackPanel>
            </Button>
        </Grid>

        <TextBlock Text="{Binding HistoryInfo}"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="9"
                   Margin="4,2"
                   TextAlignment="Center"/>

        <Separator Style="{StaticResource PanelSeparator}"/>

        <!-- ── AutoFix Optimizer ──────────────────────────────────────── -->
        <TextBlock Style="{StaticResource SectionHeader}"
                   Text="🤖 AutoFix - Modell-Optimierung"/>

        <TextBlock Text="Der Assistent optimiert dein Modell automatisch für optimale Druckergebnisse!"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="4,4"/>

        <!-- Analysis Report -->
        <Border Background="#0F1419"
                BorderBrush="#374151"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8"
                Margin="4,6"
                Visibility="{Binding HasAnalysisReport, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="{Binding AnalysisReportTitle}"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>

                <!-- Print Quality Score -->
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Druckqualität:"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="10"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding PrintQualityScore, StringFormat='{}{0}%'}"
                               Foreground="{Binding PrintQualityColor}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               TextAlignment="Right"/>
                </Grid>

                <!-- Issues Found -->
                <ItemsControl ItemsSource="{Binding IssuesFound}" Margin="0,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       Foreground="#FFA500"
                                       FontSize="9"
                                       TextWrapping="Wrap"
                                       Margin="0,2"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Recommendations -->
                <ItemsControl ItemsSource="{Binding Recommendations}" Margin="0,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       Foreground="#90EE90"
                                       FontSize="9"
                                       TextWrapping="Wrap"
                                       Margin="0,2"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Optimization Options -->
        <Border Background="#0F1419"
                BorderBrush="#374151"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8"
                Margin="4,6">
            <StackPanel>
                <TextBlock Text="Optimierungsoptionen:"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>

                <!-- Fillet Radius -->
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Fillet-Radius:"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"
                               FontSize="10"/>

                    <TextBox Grid.Column="1"
                             Text="{Binding FilletRadius, UpdateSourceTrigger=LostFocus, StringFormat=N1}"
                             Style="{StaticResource NumericInput}"
                             materialDesign:HintAssist.Hint="mm"/>
                </Grid>

                <!-- Min Wall Thickness -->
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Min. Wandstärke:"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"
                               FontSize="10"/>

                    <TextBox Grid.Column="1"
                             Text="{Binding MinWallThickness, UpdateSourceTrigger=LostFocus, StringFormat=N1}"
                             Style="{StaticResource NumericInput}"
                             materialDesign:HintAssist.Hint="mm"/>
                </Grid>

                <!-- Min Hole Size -->
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Min. Lochgröße:"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"
                               FontSize="10"/>

                    <TextBox Grid.Column="1"
                             Text="{Binding MinHoleSize, UpdateSourceTrigger=LostFocus, StringFormat=N1}"
                             Style="{StaticResource NumericInput}"
                             materialDesign:HintAssist.Hint="mm"/>
                </Grid>

                <Separator Background="#2D3748" Margin="0,6"/>

                <!-- Checkboxes for options -->
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Kleine Löcher füllen"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"
                               FontSize="10"/>

                    <CheckBox Grid.Column="1"
                              IsChecked="{Binding RemoveSmallHoles}"
                              VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Nicht-manifold Geometrie reparieren"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"
                               FontSize="10"/>

                    <CheckBox Grid.Column="1"
                              IsChecked="{Binding FixNonManifold}"
                              VerticalAlignment="Center"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Mesh glätten"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"
                               FontSize="10"/>

                    <CheckBox Grid.Column="1"
                              IsChecked="{Binding SmoothMesh}"
                              VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Printer Profile Selection -->
        <TextBlock Style="{StaticResource SectionHeader}"
                   Text="Drucker-Profil"
                   Margin="0,8,0,0"/>

        <ComboBox ItemsSource="{Binding AvailablePrinters}"
                  SelectedItem="{Binding SelectedPrinter}"
                  DisplayMemberPath="Name"
                  Background="#1F2937"
                  Foreground="{StaticResource TextPrimary}"
                  BorderBrush="#374151"
                  Margin="4,4"/>

        <TextBlock Text="Wähle dein Drucker-Modell für optimale Einstellungen"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="9"
                   Margin="4,2"/>

        <Separator Style="{StaticResource PanelSeparator}"/>

        <!-- Action Buttons -->
        <Button Command="{Binding AnalyzeCommand}"
                IsEnabled="{Binding HasSelectedObject}"
                Style="{StaticResource ActionButton}"
                HorizontalAlignment="Stretch"
                Margin="4,4">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Magnify" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding AnalyzeButtonText}"/>
            </StackPanel>
        </Button>

        <Button Command="{Binding AutoFixCommand}"
                IsEnabled="{Binding CanAutoFix}"
                HorizontalAlignment="Stretch"
                Margin="4,2" Height="40" FontSize="12" FontWeight="SemiBold"
                Background="#10B981" Foreground="White"
                Style="{StaticResource MaterialDesignRaisedButton}"
                Cursor="Hand">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="RobotHappy" Width="20" Height="20" Margin="0,0,8,0"/>
                <TextBlock Text="🤖 AutoFix starten!"/>
            </StackPanel>
        </Button>

        <!-- Progress Indicator -->
        <ProgressBar IsIndeterminate="True"
                     Height="3"
                     Margin="4,4"
                     Visibility="{Binding IsOptimizing, Converter={StaticResource BoolToVisibilityConverter}}"
                     Foreground="#60A5FA"/>

        <TextBlock Text="{Binding OptimizationProgress}"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="9"
                   Margin="4,2"
                   TextAlignment="Center"
                   Visibility="{Binding IsOptimizing, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Mascot Animation Display -->
        <Border Background="#0F1419"
                BorderBrush="#60A5FA"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8"
                Margin="4,4"
                Visibility="{Binding IsOptimizing, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="🤖 Der Assistent optimiert dein Modell..."
                           Foreground="#60A5FA"
                           FontSize="10"
                           FontWeight="SemiBold"
                           TextAlignment="Center"/>
                
                <!-- Animated Mascot with Tools -->
                <local:MascotAnimationView x:Name="MascotAnimator"
                                           Height="120"
                                           Margin="0,8,0,0"
                                           CurrentTool="{Binding CurrentMascotTool}"/>
                
                <TextBlock Text="{Binding MascotAnimationText}"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="9"
                           TextAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
