<UserControl x:Class="ThreeDBuilder.Views.UpdateToolbarButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        
        <!-- Update Button -->
        <Button x:Name="UpdateButton"
                Command="{Binding CheckForUpdatesCommand}"
                ToolTip="Nach Updates suchen"
                Style="{StaticResource MaterialDesignFlatButton}"
                Background="Transparent"
                Foreground="#60A5FA"
                Padding="8"
                Margin="4,0"
                Cursor="Hand">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="CloudDownload" Width="18" Height="18" VerticalAlignment="Center"/>
                <TextBlock Text="Updates" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="11"/>
            </StackPanel>
        </Button>

        <!-- Update Available Indicator -->
        <Border Background="#10B981" 
                CornerRadius="10" 
                Padding="6,2"
                Margin="4,0"
                Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Update verfügbar!" 
                       Foreground="White" 
                       FontSize="9" 
                       FontWeight="SemiBold"/>
        </Border>

    </StackPanel>
</UserControl>
