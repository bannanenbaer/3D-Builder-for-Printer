<UserControl x:Class="ThreeDBuilder.Views.UpdateToolbarButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
        
        <!-- Update Button -->
        <Button x:Name="UpdateButton"
                Command="{Binding CheckForUpdatesCommand}"
                ToolTip="Nach Updates suchen"
                Style="{StaticResource MaterialDesignFlatButton}"
                Background="Transparent"
                Foreground="#60A5FA"
                Padding="12,6"
                Margin="0,0,8,0"
                Cursor="Hand"
                Opacity="0.85">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="CloudDownload" Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="Updates" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11" FontWeight="Medium"/>
            </StackPanel>
        </Button>

        <!-- Update Available Indicator (animated) -->
        <Border Background="#10B981" 
                CornerRadius="12" 
                Padding="10,4"
                Margin="0,0,0,0"
                Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="AlertCircle" Width="12" Height="12" Foreground="White" Margin="0,0,4,0"/>
                <TextBlock Text="Update verfügbar!" 
                           Foreground="White" 
                           FontSize="10" 
                           FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
