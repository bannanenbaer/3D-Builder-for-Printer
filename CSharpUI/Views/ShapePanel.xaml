<UserControl x:Class="ThreeDBuilder.Views.ShapePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <StackPanel Margin="8">

        <!-- ── Shapes ───────────────────────────────────────────────────── -->
        <TextBlock Style="{StaticResource SectionHeader}"
                   Text="{Binding T[panel_shapes]}"/>

        <WrapPanel Margin="0,4,0,0">
            <!-- Box -->
            <Button Style="{StaticResource ShapeButtonStyle}"
                    Command="{Binding AddShapeCommand}"
                    CommandParameter="box"
                    ToolTip="{Binding T[shape_box]}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="CubeOutline" Width="32" Height="32"
                                            HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding T[shape_box]}" TextAlignment="Center" FontSize="9" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Sphere -->
            <Button Style="{StaticResource ShapeButtonStyle}"
                    Command="{Binding AddShapeCommand}"
                    CommandParameter="sphere"
                    ToolTip="{Binding T[shape_sphere]}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="CircleOutline" Width="32" Height="32"
                                            HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding T[shape_sphere]}" TextAlignment="Center" FontSize="9" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Cylinder -->
            <Button Style="{StaticResource ShapeButtonStyle}"
                    Command="{Binding AddShapeCommand}"
                    CommandParameter="cylinder"
                    ToolTip="{Binding T[shape_cylinder]}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Cylinder" Width="32" Height="32"
                                            HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding T[shape_cylinder]}" TextAlignment="Center" FontSize="9" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Cone -->
            <Button Style="{StaticResource ShapeButtonStyle}"
                    Command="{Binding AddShapeCommand}"
                    CommandParameter="cone"
                    ToolTip="{Binding T[shape_cone]}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Triangle" Width="32" Height="32"
                                            HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding T[shape_cone]}" TextAlignment="Center" FontSize="9" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Torus -->
            <Button Style="{StaticResource ShapeButtonStyle}"
                    Command="{Binding AddShapeCommand}"
                    CommandParameter="torus"
                    ToolTip="{Binding T[shape_torus]}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Autorenew" Width="32" Height="32"
                                            HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding T[shape_torus]}" TextAlignment="Center" FontSize="9" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Prism -->
            <Button Style="{StaticResource ShapeButtonStyle}"
                    Command="{Binding AddShapeCommand}"
                    CommandParameter="prism"
                    ToolTip="{Binding T[shape_prism]}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="HexagonOutline" Width="32" Height="32"
                                            HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding T[shape_prism]}" TextAlignment="Center" FontSize="9" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Pyramid -->
            <Button Style="{StaticResource ShapeButtonStyle}"
                    Command="{Binding AddShapeCommand}"
                    CommandParameter="pyramid"
                    ToolTip="{Binding T[shape_pyramid]}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="TriangleOutline" Width="32" Height="32"
                                            HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding T[shape_pyramid]}" TextAlignment="Center" FontSize="9" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Tube -->
            <Button Style="{StaticResource ShapeButtonStyle}"
                    Command="{Binding AddShapeCommand}"
                    CommandParameter="tube"
                    ToolTip="{Binding T[shape_tube]}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Pipe" Width="32" Height="32"
                                            HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding T[shape_tube]}" TextAlignment="Center" FontSize="9" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Ellipsoid -->
            <Button Style="{StaticResource ShapeButtonStyle}"
                    Command="{Binding AddShapeCommand}"
                    CommandParameter="ellipsoid"
                    ToolTip="{Binding T[shape_ellipsoid]}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="EllipseOutline" Width="32" Height="32"
                                            HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding T[shape_ellipsoid]}" TextAlignment="Center" FontSize="9" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Hemisphere -->
            <Button Style="{StaticResource ShapeButtonStyle}"
                    Command="{Binding AddShapeCommand}"
                    CommandParameter="hemisphere"
                    ToolTip="{Binding T[shape_hemisphere]}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Brightness2" Width="32" Height="32"
                                            HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding T[shape_hemisphere]}" TextAlignment="Center" FontSize="9" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- L-Profile -->
            <Button Style="{StaticResource ShapeButtonStyle}"
                    Command="{Binding AddShapeCommand}"
                    CommandParameter="l_profile"
                    ToolTip="{Binding T[shape_l_profile]}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="AlphaL" Width="32" Height="32"
                                            HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding T[shape_l_profile]}" TextAlignment="Center" FontSize="9" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- T-Profile -->
            <Button Style="{StaticResource ShapeButtonStyle}"
                    Command="{Binding AddShapeCommand}"
                    CommandParameter="t_profile"
                    ToolTip="{Binding T[shape_t_profile]}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="AlphaT" Width="32" Height="32"
                                            HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding T[shape_t_profile]}" TextAlignment="Center" FontSize="9" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Star -->
            <Button Style="{StaticResource ShapeButtonStyle}"
                    Command="{Binding AddShapeCommand}"
                    CommandParameter="star"
                    ToolTip="{Binding T[shape_star]}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="StarOutline" Width="32" Height="32"
                                            HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding T[shape_star]}" TextAlignment="Center" FontSize="9" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Polygon -->
            <Button Style="{StaticResource ShapeButtonStyle}"
                    Command="{Binding AddShapeCommand}"
                    CommandParameter="polygon"
                    ToolTip="{Binding T[shape_polygon]}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Pentagon" Width="32" Height="32"
                                            HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding T[shape_polygon]}" TextAlignment="Center" FontSize="9" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Threaded Cylinder -->
            <Button Style="{StaticResource ShapeButtonStyle}"
                    Command="{Binding AddShapeCommand}"
                    CommandParameter="thread_cyl"
                    ToolTip="{Binding T[shape_thread_cyl]}">
                <StackPanel>
                    <materialDesign:PackIcon Kind="Cog" Width="32" Height="32"
                                            HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding T[shape_thread_cyl]}" TextAlignment="Center" FontSize="9" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Button>
        </WrapPanel>

        <Separator Style="{StaticResource PanelSeparator}"/>

        <!-- ── Import ────────────────────────────────────────────────────── -->
        <TextBlock Style="{StaticResource SectionHeader}"
                   Text="{Binding T[panel_import]}"/>

        <Button Style="{StaticResource ActionButton}"
                Command="{Binding ImportStlCommand}"
                HorizontalAlignment="Stretch"
                Margin="4,2">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Upload" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding T[btn_import_stl]}"/>
            </StackPanel>
        </Button>

        <Separator Style="{StaticResource PanelSeparator}"/>

        <!-- ── Boolean Operations ─────────────────────────────────────────── -->
        <TextBlock Style="{StaticResource SectionHeader}"
                   Text="{Binding T[panel_operations]}"/>

        <TextBlock Text="(2 Objekte auswählen)"
                   Foreground="{DynamicResource TextSecondary}"
                   FontSize="10" Margin="6,2,6,4" FontStyle="Italic"
                   Visibility="{Binding HasTwoSelections,
                       Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

        <Button Style="{StaticResource ActionButton}"
                Command="{Binding BoolUnionCommand}"
                IsEnabled="{Binding HasTwoSelections}"
                HorizontalAlignment="Stretch" Margin="4,2">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Plus" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding T[op_union]}"/>
            </StackPanel>
        </Button>

        <Button Style="{StaticResource ActionButton}"
                Command="{Binding BoolSubtractCommand}"
                IsEnabled="{Binding HasTwoSelections}"
                HorizontalAlignment="Stretch" Margin="4,2">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Minus" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding T[op_subtract]}"/>
            </StackPanel>
        </Button>

        <Button Style="{StaticResource ActionButton}"
                Command="{Binding BoolIntersectCommand}"
                IsEnabled="{Binding HasTwoSelections}"
                HorizontalAlignment="Stretch" Margin="4,2">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Asterisk" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding T[op_intersect]}"/>
            </StackPanel>
        </Button>

        <Separator Style="{StaticResource PanelSeparator}"/>

        <!-- ── Object List ─────────────────────────────────────────────────── -->
        <TextBlock Style="{StaticResource SectionHeader}"
                   Text="{Binding T[object_list]}"/>

        <ListBox ItemsSource="{Binding SceneObjects}"
                 SelectedItem="{Binding SelectedObject}"
                 Background="{DynamicResource InputBackground}"
                 Foreground="{DynamicResource TextPrimary}"
                 BorderThickness="1"
                 BorderBrush="{DynamicResource InputBorder}"
                 MaxHeight="250"
                 Padding="2">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="Transparent" Padding="6,4" CornerRadius="3">
                        <TextBlock Text="{Binding Name}" FontSize="11" Foreground="{DynamicResource TextPrimary}"/>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bd" Background="Transparent" BorderThickness="0" Padding="0">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#3B82F6"/>
                                        <Setter TargetName="Bd" Property="CornerRadius" Value="3"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2D3748"/>
                                        <Setter TargetName="Bd" Property="CornerRadius" Value="3"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

    </StackPanel>
</UserControl>
