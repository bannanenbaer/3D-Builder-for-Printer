<Window x:Class="ThreeDBuilder.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helix="http://helix-toolkit.org/wpf"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:ThreeDBuilder.Views"
        Title="3D-Builder für 3D-Druck"
        Width="1400" Height="900"
        MinWidth="1000" MinHeight="600"
        Background="{StaticResource PanelBackground}"
        WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding Command="{Binding UndoCommand}"      Gesture="Ctrl+Z"/>
        <KeyBinding Command="{Binding RedoCommand}"      Gesture="Ctrl+Y"/>
        <KeyBinding Command="{Binding DeleteCommand}"    Gesture="Delete"/>
        <KeyBinding Command="{Binding ExportStlCommand}" Gesture="Ctrl+S"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- ═══ MENU BAR ═══════════════════════════════════════════════════ -->
        <Menu DockPanel.Dock="Top" Background="#1C1C1C" Foreground="White">
            <!-- File -->
            <MenuItem Header="{Binding T[menu_file]}" Foreground="White">
                <MenuItem Header="{Binding T[action_new]}"
                          Command="{Binding NewSceneCommand}"
                          InputGestureText="Ctrl+N"/>
                <Separator/>
                <MenuItem Header="{Binding T[action_open_stl]}"
                          Command="{Binding ImportStlCommand}"/>
                <MenuItem Header="{Binding T[action_open_scad]}"
                          Command="{Binding ImportScadCommand}"/>
                <Separator/>
                <MenuItem Header="{Binding T[action_export_stl]}"
                          Command="{Binding ExportStlCommand}"
                          InputGestureText="Ctrl+S"/>
                <MenuItem Header="{Binding T[action_export_scad]}"
                          Command="{Binding ExportScadCommand}"/>
                <Separator/>
                <MenuItem Header="{Binding T[action_quit]}" Click="OnQuit"/>
            </MenuItem>
            <!-- Edit -->
            <MenuItem Header="{Binding T[menu_edit]}" Foreground="White">
                <MenuItem Header="{Binding T[action_undo]}"
                          Command="{Binding UndoCommand}"
                          InputGestureText="Ctrl+Z"/>
                <MenuItem Header="{Binding T[action_redo]}"
                          Command="{Binding RedoCommand}"
                          InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="{Binding T[action_delete]}"
                          Command="{Binding DeleteCommand}"
                          InputGestureText="Del"/>
                <MenuItem Header="{Binding T[action_duplicate]}"
                          Command="{Binding DuplicateCommand}"
                          InputGestureText="Ctrl+D"/>
            </MenuItem>
            <!-- View -->
            <MenuItem Header="{Binding T[menu_view]}" Foreground="White">
                <MenuItem Header="{Binding T[action_reset_view]}"  Click="OnResetView"/>
                <MenuItem Header="{Binding T[action_top_view]}"    Click="OnTopView"/>
                <MenuItem Header="{Binding T[action_front_view]}"  Click="OnFrontView"/>
                <MenuItem Header="{Binding T[action_side_view]}"   Click="OnSideView"/>
                <MenuItem Header="{Binding T[action_iso_view]}"    Click="OnIsometricView"/>
            </MenuItem>
            <!-- Language -->
            <MenuItem Header="{Binding T[menu_language]}" Foreground="White">
                <MenuItem Header="Deutsch" Click="OnSetDe"/>
                <MenuItem Header="English" Click="OnSetEn"/>
            </MenuItem>
            <!-- Help -->
            <MenuItem Header="{Binding T[menu_help]}" Foreground="White">
                <MenuItem Header="{Binding T[help_about]}" Click="OnAbout"/>
            </MenuItem>
        </Menu>

        <!-- ═══ TOOLBAR ════════════════════════════════════════════════════ -->
        <ToolBar DockPanel.Dock="Top" Background="#2D2D30">
            <Button ToolTip="{Binding T[action_new]}"
                    Command="{Binding NewSceneCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="White">
                <materialDesign:PackIcon Kind="FileOutline" Width="20" Height="20"/>
            </Button>
            <Button ToolTip="{Binding T[action_open_stl]}"
                    Command="{Binding ImportStlCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="White">
                <materialDesign:PackIcon Kind="FolderOpen" Width="20" Height="20"/>
            </Button>
            <Button ToolTip="{Binding T[action_export_stl]}"
                    Command="{Binding ExportStlCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="White">
                <materialDesign:PackIcon Kind="ContentSave" Width="20" Height="20"/>
            </Button>
            <Separator/>
            <Button ToolTip="{Binding T[action_undo]}"
                    Command="{Binding UndoCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="White">
                <materialDesign:PackIcon Kind="Undo" Width="20" Height="20"/>
            </Button>
            <Button ToolTip="{Binding T[action_redo]}"
                    Command="{Binding RedoCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="White">
                <materialDesign:PackIcon Kind="Redo" Width="20" Height="20"/>
            </Button>
            <Separator/>
            <Button ToolTip="{Binding T[action_delete]}"
                    Command="{Binding DeleteCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="White">
                <materialDesign:PackIcon Kind="Delete" Width="20" Height="20"/>
            </Button>
            <Button ToolTip="{Binding T[action_duplicate]}"
                    Command="{Binding DuplicateCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="White">
                <materialDesign:PackIcon Kind="ContentDuplicate" Width="20" Height="20"/>
            </Button>
        </ToolBar>

        <!-- ═══ STATUS BAR ═════════════════════════════════════════════════ -->
        <StatusBar DockPanel.Dock="Bottom" Background="#007ACC" Foreground="White">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" FontSize="12"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding T[status_objects]}" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding SceneObjects.Count}"/>
                    <TextBlock Text="  |  " Margin="4,0"/>
                    <TextBlock Text="{Binding T[status_active]}"/>
                    <TextBlock Text=": "/>
                    <TextBlock Text="{Binding SelectedObject.Name, FallbackValue='-'}"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ MAIN CONTENT ════════════════════════════════════════════════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" MinWidth="120"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="260" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- ─ LEFT SIDEBAR: Shape Library ─ -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBackground}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <local:ShapePanel x:Name="ShapePanelControl" DataContext="{Binding}"/>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1" Background="{StaticResource SeparatorBrush}"
                          HorizontalAlignment="Stretch"/>

            <!-- ─ CENTER: 3D Viewport + Tab with SCAD Editor ─ -->
            <TabControl Grid.Column="2" Background="{StaticResource PanelBackground}"
                        x:Name="MainTabControl">

                <!-- Tab 1: 3D Builder Viewport -->
                <TabItem Header="{Binding T[tab_builder]}" Foreground="White"
                         Background="{StaticResource PanelBackground}">
                    <Grid>
                        <!-- 3D Viewport -->
                        <helix:HelixViewport3D x:Name="Viewport3D"
                                               Background="#111111"
                                               ShowCoordinateSystem="True"
                                               ShowFrameRate="False"
                                               ZoomExtentsWhenLoaded="True">
                            <helix:DefaultLights/>
                            <helix:GridLinesVisual3D Width="200" Length="200"
                                                     MajorDistance="10"
                                                     MinorDistance="5"
                                                     Thickness="0.3"
                                                     Color="#444444"/>
                        </helix:HelixViewport3D>

                        <!-- Loading overlay -->
                        <Border Background="#AA000000"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ProgressBar IsIndeterminate="True" Width="200" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding StatusText}" Foreground="White"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Tab 2: OpenSCAD Editor -->
                <TabItem Header="{Binding T[tab_scad]}" Foreground="White"
                         Background="{StaticResource PanelBackground}">
                    <local:ScadEditorPanel x:Name="ScadPanel" DataContext="{Binding}"/>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="3" Background="{StaticResource SeparatorBrush}"
                          HorizontalAlignment="Stretch"/>

            <!-- ─ RIGHT SIDEBAR: Properties ─ -->
            <Border Grid.Column="4" Background="{StaticResource SidebarBackground}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <local:PropertiesPanel x:Name="PropertiesPanelControl" DataContext="{Binding}"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
