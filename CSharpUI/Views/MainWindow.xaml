    <Window x:Class="ThreeDBuilder.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helix="http://helix-toolkit.org/wpf"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:ThreeDBuilder.Views"
        Title="3D-Builder Pro | Parametrisches 3D-Modellieren"
        Width="1600" Height="1000"
        MinWidth="1200" MinHeight="700"
        Background="{DynamicResource PanelBackground}"
        Foreground="{DynamicResource TextPrimary}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        FontSize="12"
        PreviewKeyDown="OnSceneKeyDown">

    <Window.InputBindings>
        <KeyBinding Command="{Binding UndoCommand}"      Gesture="Ctrl+Z"/>
        <KeyBinding Command="{Binding RedoCommand}"      Gesture="Ctrl+Y"/>
        <KeyBinding Command="{Binding DeleteCommand}"    Gesture="Delete"/>
        <KeyBinding Command="{Binding ExportStlCommand}" Gesture="Ctrl+S"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- ═══ MENU BAR ═══════════════════════════════════════════════════ -->
        <Menu DockPanel.Dock="Top" Background="{DynamicResource PanelBackground}" Foreground="{DynamicResource TextPrimary}"
              FontSize="11" FontFamily="Segoe UI">
            <!-- File -->
            <MenuItem Header="{Binding T[menu_file]}" Foreground="{DynamicResource TextPrimary}">
                <MenuItem Header="{Binding T[action_new]}"
                          Command="{Binding NewSceneCommand}"
                          InputGestureText="Ctrl+N"/>
                <Separator/>
                <MenuItem Header="{Binding T[action_open_stl]}"
                          Command="{Binding ImportStlCommand}"/>
                <MenuItem Header="{Binding T[action_open_scad]}"
                          Command="{Binding ImportScadCommand}"/>
                <Separator/>
                <MenuItem Header="{Binding T[action_export_stl]}"
                          Command="{Binding ExportStlCommand}"
                          InputGestureText="Ctrl+S"/>
                <MenuItem Header="{Binding T[action_export_scad]}"
                          Command="{Binding ExportScadCommand}"/>
                <Separator/>
                <MenuItem Header="{Binding T[action_quit]}" Click="OnQuit"/>
            </MenuItem>
            <!-- Edit -->
            <MenuItem Header="{Binding T[menu_edit]}" Foreground="{DynamicResource TextPrimary}">
                <MenuItem Header="{Binding T[action_undo]}"
                          Command="{Binding UndoCommand}"
                          InputGestureText="Ctrl+Z"/>
                <MenuItem Header="{Binding T[action_redo]}"
                          Command="{Binding RedoCommand}"
                          InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="{Binding T[action_delete]}"
                          Command="{Binding DeleteCommand}"
                          InputGestureText="Del"/>
                <MenuItem Header="{Binding T[action_duplicate]}"
                          Command="{Binding DuplicateCommand}"
                          InputGestureText="Ctrl+D"/>
            </MenuItem>
            <!-- View -->
            <MenuItem Header="{Binding T[menu_view]}" Foreground="{DynamicResource TextPrimary}">
                <MenuItem Header="{Binding T[action_reset_view]}"  Click="OnResetView"/>
                <MenuItem Header="{Binding T[action_top_view]}"    Click="OnTopView"/>
                <MenuItem Header="{Binding T[action_front_view]}"  Click="OnFrontView"/>
                <MenuItem Header="{Binding T[action_side_view]}"   Click="OnSideView"/>
                <MenuItem Header="{Binding T[action_iso_view]}"    Click="OnIsometricView"/>
            </MenuItem>
            <!-- Settings -->
            <MenuItem Header="Einstellungen" Click="OnOpenSettings"
                      Foreground="{DynamicResource TextPrimary}"/>
            <!-- Help -->
            <MenuItem Header="{Binding T[menu_help]}" Foreground="{DynamicResource TextPrimary}">
                <MenuItem Header="{Binding T[help_about]}" Click="OnAbout"/>
            </MenuItem>
        </Menu>

        <!-- ═══ TOOLBAR ════════════════════════════════════════════════════ -->
        <ToolBar DockPanel.Dock="Top" Background="{DynamicResource SidebarBackground}" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource SeparatorBrush}">
            <Button ToolTip="{Binding T[action_new]}"
                    Command="{Binding NewSceneCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="{DynamicResource TextPrimary}"
                    Padding="6,4">
                <materialDesign:PackIcon Kind="FileOutline" Width="18" Height="18"/>
            </Button>
            <Button ToolTip="{Binding T[action_open_stl]}"
                    Command="{Binding ImportStlCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="{DynamicResource TextPrimary}"
                    Padding="6,4">
                <materialDesign:PackIcon Kind="FolderOpen" Width="18" Height="18"/>
            </Button>
            <Button ToolTip="{Binding T[action_export_stl]}"
                    Command="{Binding ExportStlCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="{DynamicResource TextPrimary}"
                    Padding="6,4">
                <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18"/>
            </Button>
            <Separator Background="{DynamicResource SeparatorBrush}" Margin="2,4"/>
            <Button ToolTip="{Binding T[action_undo]}"
                    Command="{Binding UndoCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="{DynamicResource TextPrimary}"
                    Padding="6,4">
                <materialDesign:PackIcon Kind="Undo" Width="18" Height="18"/>
            </Button>
            <Button ToolTip="{Binding T[action_redo]}"
                    Command="{Binding RedoCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="{DynamicResource TextPrimary}"
                    Padding="6,4">
                <materialDesign:PackIcon Kind="Redo" Width="18" Height="18"/>
            </Button>
            <Separator Background="{DynamicResource SeparatorBrush}" Margin="2,4"/>
            <Button ToolTip="{Binding T[action_delete]}"
                    Command="{Binding DeleteCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="{DynamicResource TextPrimary}"
                    Padding="6,4">
                <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"/>
            </Button>
            <Button ToolTip="{Binding T[action_duplicate]}"
                    Command="{Binding DuplicateCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="{DynamicResource TextPrimary}"
                    Padding="6,4">
                <materialDesign:PackIcon Kind="ContentDuplicate" Width="18" Height="18"/>
            </Button>
        </ToolBar>

        <!-- ═══ STATUS BAR ═════════════════════════════════════════════════ -->
        <StatusBar DockPanel.Dock="Bottom" Background="{DynamicResource SidebarBackground}" Foreground="{DynamicResource TextPrimary}"
                   BorderThickness="0,1,0,0" BorderBrush="{DynamicResource SeparatorBrush}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" FontSize="12"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding T[status_objects]}" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding SceneObjects.Count}"/>
                    <TextBlock Text="  |  " Margin="4,0"/>
                    <TextBlock Text="{Binding T[status_active]}"/>
                    <TextBlock Text=": "/>
                    <TextBlock Text="{Binding SelectedObject.Name, FallbackValue='-'}"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ MAIN CONTENT ════════════════════════════════════════════════ -->
        <Grid x:Name="RootContentGrid">
            <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" MinWidth="140"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="300" MinWidth="250"/>
            </Grid.ColumnDefinitions>

            <!-- ─ LEFT SIDEBAR: Shape Library ─ -->
            <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <local:ShapePanel x:Name="ShapePanelControl" DataContext="{Binding}"/>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1" Background="{DynamicResource SeparatorBrush}"
                          HorizontalAlignment="Stretch" ShowsPreview="False"/>

            <!-- ─ CENTER: 3D Viewport + Tab with SCAD Editor ─ -->
            <TabControl Grid.Column="2" Background="{DynamicResource PanelBackground}"
                        x:Name="MainTabControl">

                <!-- Tab 1: 3D Builder Viewport -->
                <TabItem Header="{Binding T[tab_builder]}" Foreground="{DynamicResource TextPrimary}"
                         Background="{DynamicResource PanelBackground}">
                    <Grid>
                        <!-- 3D Viewport -->
                        <helix:HelixViewport3D x:Name="Viewport3D"
                                               Background="{DynamicResource ViewportBackground}"
                                               ShowCoordinateSystem="True"
                                               ShowFrameRate="False"
                                               ZoomExtentsWhenLoaded="True"
                                               PreviewMouseLeftButtonDown="OnViewportMouseLeftButtonDown">
                            <helix:DefaultLights/>
                            <!-- Normal="0,0,1" → Grid liegt in der XY-Ebene (Z=0 = Druckbett), Z zeigt nach oben -->
                            <helix:GridLinesVisual3D Width="200" Length="200"
                                                     Normal="0,0,1"
                                                     MajorDistance="10"
                                                     MinorDistance="5"
                                                     Thickness="0.3"/>
                        </helix:HelixViewport3D>

                        <!-- Loading overlay -->
                        <Border Background="#CC000000"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ProgressBar IsIndeterminate="True" Width="240" Margin="0,0,0,12" Height="4"/>
                                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextPrimary}"
                                           HorizontalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <!-- ── Mascot viewport overlay (AutoFix walk animation) ── -->
                        <Canvas x:Name="ViewportMascotLayer"
                                IsHitTestVisible="False"
                                Background="Transparent">
                            <local:MascotAnimationView x:Name="ViewportMascot"
                                                       Width="120" Height="150"
                                                       Canvas.Bottom="18"
                                                       Visibility="Collapsed"/>
                        </Canvas>

                    </Grid>
                </TabItem>

                <!-- Tab 2: OpenSCAD Editor -->
                <TabItem Header="{Binding T[tab_scad]}" Foreground="{DynamicResource TextPrimary}"
                         Background="{DynamicResource PanelBackground}">
                    <local:ScadEditorPanel x:Name="ScadPanel" DataContext="{Binding}"/>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="3" Background="{DynamicResource SeparatorBrush}"
                          HorizontalAlignment="Stretch" ShowsPreview="False"/>

            <!-- ─ RIGHT SIDEBAR: Properties + AutoFix tabs ─ -->
            <Border Grid.Column="4" Background="{DynamicResource SidebarBackground}">
                <TabControl Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource TextPrimary}">
                    <TabItem Header="Eigenschaften" Foreground="{DynamicResource TextPrimary}"
                             Background="Transparent">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <local:PropertiesPanel x:Name="PropertiesPanelControl" DataContext="{Binding}"/>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="AutoFix" Foreground="{DynamicResource TextPrimary}"
                             Background="Transparent">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <local:AutoFixPanel x:Name="AutoFixPanelControl"
                                                DataContext="{Binding AutoFixVM}"/>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>
            </Grid>

            <!-- ═══ TUTORIAL OVERLAY (Mascot-gesteuert, erster Start) ════════ -->
            <Border x:Name="TutorialOverlay"
                    Visibility="Collapsed"
                    Background="#BB000000"
                    Panel.ZIndex="100">
                <Grid>

                    <!-- Schritt-Punkte oben Mitte -->
                    <ItemsControl x:Name="TutorialDotsList"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Top"
                                  Margin="0,18,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <!-- Untere Leiste: Maskottchen + Sprechblase -->
                    <Border VerticalAlignment="Bottom"
                            Background="{DynamicResource PanelBackground}"
                            BorderBrush="#3B82F6"
                            BorderThickness="0,2,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Maskottchen -->
                            <Border Grid.Column="0"
                                    Padding="20,16"
                                    Background="{DynamicResource SidebarBackground}">
                                <local:MascotAnimationView x:Name="TutorialMascot"
                                                           Width="110" Height="130"
                                                           VerticalAlignment="Bottom"/>
                            </Border>

                            <!-- Sprechblase -->
                            <Grid Grid.Column="1" Margin="24,20,28,20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="TutorialStepTitle"
                                           Grid.Row="0"
                                           FontSize="17" FontWeight="Bold"
                                           Foreground="#F8FAFC"
                                           Margin="0,0,0,8"/>

                                <TextBlock x:Name="TutorialStepText"
                                           Grid.Row="1"
                                           FontSize="13"
                                           Foreground="#CBD5E1"
                                           TextWrapping="Wrap"
                                           LineHeight="22"/>

                                <StackPanel Grid.Row="2"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,18,0,0">
                                    <Button x:Name="TutorialPrevBtn"
                                            Content="◀ Zurück"
                                            Click="OnTutorialPrev"
                                            Visibility="Collapsed"
                                            Padding="16,8"
                                            Margin="0,0,10,0"
                                            FontSize="12"
                                            Background="{DynamicResource SeparatorBrush}"
                                            Foreground="#F8FAFC"
                                            BorderThickness="0"
                                            Cursor="Hand"/>
                                    <Button x:Name="TutorialNextBtn"
                                            Content="Weiter ▶"
                                            Click="OnTutorialNext"
                                            Padding="22,8"
                                            FontSize="12"
                                            Background="#3B82F6"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"/>
                                    <Button x:Name="TutorialFinishBtn"
                                            Content="Los geht's! 🚀"
                                            Click="OnTutorialDismiss"
                                            Visibility="Collapsed"
                                            Padding="28,8"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Background="#10B981"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
