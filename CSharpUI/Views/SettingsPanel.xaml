<UserControl x:Class="ThreeDBuilder.Views.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8" Background="{DynamicResource SidebarBackground}">

            <!-- ══ UPDATE ══════════════════════════════════════════════════ -->
            <TextBlock Style="{StaticResource SectionHeader}" Text="Update"/>

            <Border Background="#0F1419"
                    BorderBrush="#374151"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10"
                    Margin="4,4">
                <StackPanel>

                    <!-- Version row -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding UpdateVM.CurrentVersion, StringFormat='Installiert: v{0}'}"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Auf Updates prüfen"
                                Command="{Binding UpdateVM.CheckForUpdatesCommand}"
                                IsEnabled="{Binding UpdateVM.IsCheckingForUpdates,
                                            Converter={StaticResource InvertBoolConverter}}"
                                Style="{StaticResource ActionButton}"
                                FontSize="10"
                                Height="28"
                                Padding="8,0"/>
                    </Grid>

                    <!-- Status row (checking spinner / result message) -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Dot: visible only while checking -->
                        <Ellipse Grid.Column="0"
                                 Width="8" Height="8"
                                 Fill="{DynamicResource AccentBrush}"
                                 Margin="0,0,6,0"
                                 VerticalAlignment="Center"
                                 Visibility="{Binding UpdateVM.IsCheckingForUpdates,
                                              Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding UpdateVM.StatusMessage}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="10"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Progress bar (only visible when downloading) -->
                    <ProgressBar Value="{Binding UpdateVM.UpdateProgress}"
                                 Minimum="0" Maximum="100"
                                 Height="4"
                                 Margin="0,2,0,4"
                                 Foreground="{DynamicResource AccentBrush}"
                                 Background="#374151">
                        <ProgressBar.Visibility>
                            <Binding Path="UpdateVM.IsDownloading"
                                     Converter="{StaticResource BoolToVisibilityConverter}"/>
                        </ProgressBar.Visibility>
                    </ProgressBar>

                    <!-- Download/Install button (only when update available) -->
                    <Button Content="Herunterladen und installieren"
                            Command="{Binding UpdateVM.DownloadAndInstallCommand}"
                            Style="{StaticResource ActionButton}"
                            FontSize="10"
                            Height="28"
                            HorizontalAlignment="Stretch">
                        <Button.Visibility>
                            <Binding Path="UpdateVM.UpdateAvailable"
                                     Converter="{StaticResource BoolToVisibilityConverter}"/>
                        </Button.Visibility>
                    </Button>

                </StackPanel>
            </Border>

            <!-- Python Backend Status -->
            <Border Background="#0F1419"
                    BorderBrush="#374151"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8"
                    Margin="4,2,4,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0"
                             Width="8" Height="8"
                             Fill="{Binding PythonStatusBrush}"
                             Margin="0,0,6,0"
                             VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding PythonStatusText}"
                               FontSize="10"
                               Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <Separator Style="{StaticResource PanelSeparator}"/>

            <!-- ══ ERSCHEINUNGSBILD ════════════════════════════════════════ -->
            <TextBlock Style="{StaticResource SectionHeader}" Text="Erscheinungsbild"/>

            <!-- Farbmodus -->
            <Grid Margin="4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="130"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Farbmodus:"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"
                           FontSize="11"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AvailableThemes}"
                          SelectedItem="{Binding ThemeMode}"
                          Background="#1F2937"
                          Foreground="{DynamicResource TextPrimary}"
                          BorderBrush="#374151"
                          FontSize="11"/>
            </Grid>

            <!-- Schriftgröße -->
            <Grid Margin="4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Schriftgröße:"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"
                           FontSize="11"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding FontScalePercent, StringFormat='{}{0}%'}"
                           Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center"
                           FontSize="11"
                           HorizontalAlignment="Right"/>
            </Grid>
            <Slider Margin="4,2,4,6"
                    Minimum="80" Maximum="150"
                    Value="{Binding FontScalePercent}"
                    SmallChange="5" LargeChange="10"
                    Foreground="{DynamicResource AccentBrush}"
                    TickFrequency="10"
                    IsSnapToTickEnabled="True"/>

            <!-- Farbenblind-Modus -->
            <Grid Margin="4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="130"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Farbenblind-Modus:"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"
                           FontSize="11"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AvailableColorBlindModes}"
                          SelectedItem="{Binding ColorBlindMode}"
                          Background="#1F2937"
                          Foreground="{DynamicResource TextPrimary}"
                          BorderBrush="#374151"
                          FontSize="11"/>
            </Grid>

            <Separator Style="{StaticResource PanelSeparator}"/>

            <!-- ══ SPRACHE ═════════════════════════════════════════════════ -->
            <TextBlock Style="{StaticResource SectionHeader}" Text="Sprache"/>

            <Grid Margin="4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="130"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Sprache:"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"
                           FontSize="11"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AvailableLanguages}"
                          SelectedItem="{Binding Language}"
                          Background="#1F2937"
                          Foreground="{DynamicResource TextPrimary}"
                          BorderBrush="#374151"
                          FontSize="11"/>
            </Grid>

            <Separator Style="{StaticResource PanelSeparator}"/>

            <!-- ══ DRUCKBETT ═══════════════════════════════════════════════ -->
            <TextBlock Style="{StaticResource SectionHeader}" Text="Druckbett"/>

            <!-- Drucker-Voreinstellung -->
            <Grid Margin="4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="130"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Voreinstellung:"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"
                           FontSize="11"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AvailablePrinterPresets}"
                          SelectedItem="{Binding PrinterPreset}"
                          Background="#1F2937"
                          Foreground="{DynamicResource TextPrimary}"
                          BorderBrush="#374151"
                          FontSize="11"/>
            </Grid>

            <!-- Breite -->
            <Grid Margin="4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Breite (mm):"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"
                           FontSize="11"/>
                <TextBox Grid.Column="1"
                         Text="{Binding PrinterBedWidth, UpdateSourceTrigger=LostFocus}"
                         Style="{StaticResource NumericInput}"
                         FontSize="11"/>
            </Grid>

            <!-- Tiefe -->
            <Grid Margin="4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Tiefe (mm):"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"
                           FontSize="11"/>
                <TextBox Grid.Column="1"
                         Text="{Binding PrinterBedDepth, UpdateSourceTrigger=LostFocus}"
                         Style="{StaticResource NumericInput}"
                         FontSize="11"/>
            </Grid>

            <Separator Style="{StaticResource PanelSeparator}"/>

            <!-- ══ AUTOSAVE ════════════════════════════════════════════════ -->
            <TextBlock Style="{StaticResource SectionHeader}" Text="Autosave"/>

            <!-- Toggle -->
            <Grid Margin="4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Automatisch speichern:"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"
                           FontSize="11"/>
                <ToggleButton Grid.Column="1"
                              IsChecked="{Binding AutoSaveEnabled}"
                              Style="{StaticResource ToggleSwitchStyle}"
                              VerticalAlignment="Center"/>
            </Grid>

            <!-- Pfad -->
            <TextBlock Text="Speicherpfad:"
                       Foreground="{DynamicResource TextPrimary}"
                       FontSize="11"
                       Margin="4,6,4,2"/>
            <Grid Margin="4,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding AutoSavePath, UpdateSourceTrigger=LostFocus}"
                         Background="#1F2937"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="#374151"
                         FontSize="10"
                         Padding="4,3"
                         IsEnabled="{Binding AutoSaveEnabled}"
                         VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="Durchsuchen"
                        Command="{Binding BrowseAutoSavePathCommand}"
                        IsEnabled="{Binding AutoSaveEnabled}"
                        Style="{StaticResource ActionButton}"
                        FontSize="10"
                        Height="28"
                        Padding="6,0"
                        Margin="4,0,0,0"/>
                <Button Grid.Column="2"
                        Content="Öffnen"
                        Command="{Binding OpenAutoSaveFolderCommand}"
                        IsEnabled="{Binding AutoSaveEnabled}"
                        Style="{StaticResource ActionButton}"
                        FontSize="10"
                        Height="28"
                        Padding="6,0"
                        Margin="4,0,0,0"/>
            </Grid>

            <!-- Intervall -->
            <Grid Margin="4,6,4,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="55"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Intervall:"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"
                           FontSize="11"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding AutoSaveIntervalMinutes, StringFormat='{}{0} Min'}"
                           Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center"
                           FontSize="11"
                           HorizontalAlignment="Right"/>
            </Grid>
            <Slider Margin="4,2,4,8"
                    Minimum="1" Maximum="60"
                    Value="{Binding AutoSaveIntervalMinutes}"
                    SmallChange="1" LargeChange="5"
                    IsEnabled="{Binding AutoSaveEnabled}"
                    Foreground="{DynamicResource AccentBrush}"
                    TickFrequency="5"
                    IsSnapToTickEnabled="True"/>

            <Separator Style="{StaticResource PanelSeparator}"/>

            <!-- ══ ASSISTENT (BRIXL) ════════════════════════════════════════ -->
            <TextBlock Style="{StaticResource SectionHeader}" Text="Assistent (Brixl)"/>

            <Border Background="#0F1419"
                    BorderBrush="#374151"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8"
                    Margin="4,4">
                <StackPanel>

                    <!-- Aktiviert -->
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Aktiviert"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="11"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="KI-Assistenten Brixl aktivieren"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="9"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding IsAssistantEnabled}"
                                      Style="{StaticResource ToggleSwitchStyle}"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Background="#2D3748" Margin="0,6"/>

                    <!-- Animationen -->
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Animationen"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="11"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Süße Animationen des Assistenten"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="9"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding AnimationsEnabled}"
                                      IsEnabled="{Binding IsAssistantEnabled}"
                                      Style="{StaticResource ToggleSwitchStyle}"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Background="#2D3748" Margin="0,6"/>

                    <!-- Automatische Vorschläge -->
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Automatische Vorschläge"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="11"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Vorschläge basierend auf deinen Aktionen"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="9"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding AutoSuggestionsEnabled}"
                                      IsEnabled="{Binding IsAssistantEnabled}"
                                      Style="{StaticResource ToggleSwitchStyle}"
                                      VerticalAlignment="Center"/>
                    </Grid>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
