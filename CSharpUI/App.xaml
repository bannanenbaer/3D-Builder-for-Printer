<Application x:Class="ThreeDBuilder.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:ThreeDBuilder.Services"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Material Design theme -->
                <materialDesign:BundledTheme BaseTheme="Dark"
                                             PrimaryColor="BlueGrey"
                                             SecondaryColor="Cyan" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <local:BoolToVisibilityConverter        x:Key="BoolToVisibilityConverter"/>
            <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
            <local:InvertBoolConverter             x:Key="InvertBoolConverter"/>
            <local:BoolToColorConverter            x:Key="BoolToColorConverter"/>
            <local:CountToVisibilityConverter       x:Key="CountToVisibilityConverter"/>

            <!-- Effects -->
            <DropShadowEffect x:Key="DropShadowEffect"
                              Color="#000000"
                              Direction="270"
                              ShadowDepth="4"
                              BlurRadius="12"
                              Opacity="0.5"/>

            <!-- App-wide colors - Premium Dark Theme -->
            <SolidColorBrush x:Key="PanelBackground"   Color="#0F1419"/>
            <SolidColorBrush x:Key="SidebarBackground"  Color="#1A1F2E"/>
            <SolidColorBrush x:Key="CardBackground"     Color="#1F2937"/>
            <SolidColorBrush x:Key="CardHover"          Color="#2D3748"/>
            <SolidColorBrush x:Key="InputBackground"    Color="#1F2937"/>
            <SolidColorBrush x:Key="InputBorder"        Color="#374151"/>
            <SolidColorBrush x:Key="ButtonHighlight"    Color="#3B82F6"/>
            <SolidColorBrush x:Key="AccentBrush"        Color="#60A5FA"/>
            <SolidColorBrush x:Key="TextPrimary"        Color="#F8FAFC"/>
            <SolidColorBrush x:Key="TextSecondary"      Color="#94A3B8"/>
            <SolidColorBrush x:Key="SeparatorBrush"     Color="#2D3748"/>
            <SolidColorBrush x:Key="SuccessBrush"       Color="#10B981"/>
            <SolidColorBrush x:Key="WarningBrush"       Color="#F59E0B"/>
            <SolidColorBrush x:Key="ErrorBrush"         Color="#EF4444"/>
            <SolidColorBrush x:Key="InfoBrush"          Color="#06B6D4"/>
            <SolidColorBrush x:Key="BrixelAccent"      Color="#14B8A6"/>
            <SolidColorBrush x:Key="PanelAlt"          Color="#252D3D"/>

            <!-- Shape button style - uses DynamicResource so theme switching works -->
            <Style x:Key="ShapeButtonStyle" TargetType="Button"
                   BasedOn="{StaticResource MaterialDesignFlatButton}">
                <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
                <Setter Property="Background"      Value="{DynamicResource CardBackground}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource InputBorder}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Margin"          Value="6"/>
                <Setter Property="Height"          Value="90"/>
                <Setter Property="Width"           Value="110"/>
                <Setter Property="FontSize"        Value="11"/>
                <Setter Property="FontWeight"      Value="Medium"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Padding"         Value="6"/>
                <Setter Property="CornerRadius"    Value="8"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#000000" Opacity="0.3" BlurRadius="6" ShadowDepth="2"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background"  Value="{DynamicResource ButtonHighlight}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        <Setter Property="BorderThickness" Value="2"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#3B82F6" Opacity="0.6" BlurRadius="12" ShadowDepth="4"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Section header style - Premium typography -->
            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="Foreground"  Value="{DynamicResource AccentBrush}"/>
                <Setter Property="FontSize"    Value="13"/>
                <Setter Property="FontWeight"  Value="Bold"/>
                <Setter Property="Margin"      Value="8,14,8,8"/>
                <Setter Property="FontFamily"  Value="Segoe UI"/>
                <Setter Property="Opacity"     Value="1"/>
                <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            </Style>

            <!-- Separator style - Subtle and elegant -->
            <Style x:Key="PanelSeparator" TargetType="Separator">
                <Setter Property="Background" Value="{DynamicResource SeparatorBrush}"/>
                <Setter Property="Margin"     Value="6,6"/>
                <Setter Property="Height"     Value="1"/>
            </Style>

            <!-- Numeric input style - Modern with better UX -->
            <Style x:Key="NumericInput" TargetType="TextBox"
                   BasedOn="{StaticResource MaterialDesignTextBox}">
                <Setter Property="Width"       Value="85"/>
                <Setter Property="FontSize"    Value="12"/>
                <Setter Property="Foreground"  Value="{DynamicResource TextPrimary}"/>
                <Setter Property="Background"  Value="{DynamicResource InputBackground}"/>
                <Setter Property="HorizontalContentAlignment" Value="Right"/>
                <Setter Property="Padding"     Value="8,4"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
            </Style>

            <!-- Action button style - Premium with hover effects -->
            <Style x:Key="ActionButton" TargetType="Button"
                   BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Background"  Value="{DynamicResource ButtonHighlight}"/>
                <Setter Property="Foreground"  Value="White"/>
                <Setter Property="Margin"      Value="3,2"/>
                <Setter Property="FontSize"    Value="11"/>
                <Setter Property="FontWeight"  Value="SemiBold"/>
                <Setter Property="Height"      Value="32"/>
                <Setter Property="Padding"     Value="12,0"/>
                <Setter Property="Cursor"      Value="Hand"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#60A5FA"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Toggle switch style – self-contained, no MaterialDesign key required -->
            <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
                <Setter Property="Cursor"    Value="Hand"/>
                <Setter Property="Width"     Value="44"/>
                <Setter Property="Height"    Value="24"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Track"
                                    Width="44" Height="24"
                                    CornerRadius="12"
                                    Background="#374151">
                                <Ellipse x:Name="Thumb"
                                         Width="18" Height="18"
                                         HorizontalAlignment="Left"
                                         Margin="3,0,0,0"
                                         Fill="#94A3B8">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Track" Property="Background" Value="#3B82F6"/>
                                    <Setter TargetName="Thumb" Property="Fill"       Value="White"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="Thumb"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                    To="20" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="Thumb"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                    To="0" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Track" Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
