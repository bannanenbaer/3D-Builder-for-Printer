<Application x:Class="ThreeDBuilder.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:ThreeDBuilder.Services"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Material Design theme -->
                <materialDesign:BundledTheme BaseTheme="Dark"
                                             PrimaryColor="BlueGrey"
                                             SecondaryColor="Cyan" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <local:BoolToVisibilityConverter        x:Key="BoolToVisibilityConverter"/>
            <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

            <!-- App-wide colors -->
            <SolidColorBrush x:Key="PanelBackground"  Color="#1E1E1E"/>
            <SolidColorBrush x:Key="SidebarBackground" Color="#252526"/>
            <SolidColorBrush x:Key="ButtonHighlight"  Color="#0078D4"/>
            <SolidColorBrush x:Key="AccentBrush"      Color="#00B4D8"/>
            <SolidColorBrush x:Key="TextPrimary"      Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextSecondary"    Color="#AAAAAA"/>
            <SolidColorBrush x:Key="SeparatorBrush"   Color="#3C3C3C"/>

            <!-- Shape button style -->
            <Style x:Key="ShapeButtonStyle" TargetType="Button"
                   BasedOn="{StaticResource MaterialDesignFlatButton}">
                <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
                <Setter Property="Background"   Value="Transparent"/>
                <Setter Property="BorderBrush"  Value="{StaticResource SeparatorBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Margin"       Value="2"/>
                <Setter Property="Height"       Value="60"/>
                <Setter Property="Width"        Value="110"/>
                <Setter Property="FontSize"     Value="11"/>
                <Setter Property="Cursor"       Value="Hand"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource ButtonHighlight}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Section header style -->
            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="Foreground"  Value="{StaticResource TextSecondary}"/>
                <Setter Property="FontSize"    Value="10"/>
                <Setter Property="FontWeight"  Value="Bold"/>
                <Setter Property="Margin"      Value="5,8,5,4"/>
            </Style>

            <!-- Separator style -->
            <Style x:Key="PanelSeparator" TargetType="Separator">
                <Setter Property="Background" Value="{StaticResource SeparatorBrush}"/>
                <Setter Property="Margin"     Value="5,4"/>
            </Style>

            <!-- Numeric input style -->
            <Style x:Key="NumericInput" TargetType="TextBox"
                   BasedOn="{StaticResource MaterialDesignTextBox}">
                <Setter Property="Width"       Value="80"/>
                <Setter Property="FontSize"    Value="12"/>
                <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
                <Setter Property="HorizontalContentAlignment" Value="Right"/>
            </Style>

            <!-- Action button style -->
            <Style x:Key="ActionButton" TargetType="Button"
                   BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Background"  Value="{StaticResource ButtonHighlight}"/>
                <Setter Property="Foreground"  Value="White"/>
                <Setter Property="Margin"      Value="2"/>
                <Setter Property="FontSize"    Value="11"/>
                <Setter Property="Height"      Value="30"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
